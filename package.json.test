{
  "name": "agentflow-pro-test-configuration",
  "version": "1.0.0",
  "description": "Test configuration for AgentFlow Pro hotel management system",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/__tests__/unit",
    "test:api": "jest --testPathPattern=src/__tests__/api",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:mobile": "playwright test --config=playwright.mobile.config.ts",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "test:ci": "jest --coverage --ci && playwright test --reporter=junit",
    "pretest": "npm run lint:fix",
    "test:role-access": "jest src/__tests__/auth/role-based-access.test.ts",
    "test:receptor-api": "jest src/__tests__/api/receptor/",
    "test:mobile-responsive": "playwright test src/__tests__/mobile/receptor-responsive.test.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/__tests__/**",
      "!src/**/*.stories.{ts,tsx}",
      "!src/**/index.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": ["<rootDir>/src/__tests__/setup.ts"],
    "testTimeout": 10000,
    "verbose": true,
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "playwright": {
    "testDir": "./src/__tests__/e2e",
    "fullyParallel": true,
    "forbidOnly": false,
    "retries": 2,
    "workers": process.env.CI ? 1 : undefined,
    "reporter": [
      ["html"],
      ["junit", { outputFile: "test-results/junit.xml" }],
      ["line"],
      ["list"]
    ],
    "use": {
      "trace": "on-first-retry",
      "screenshot": "only-on-failure",
      "video": "retain-on-failure"
    },
    "projects": [
      {
        "name": "chromium",
        "use": { ...devices["Desktop Chrome"] }
      },
      {
        "name": "firefox",
        "use": { ...devices["Desktop Firefox"] }
      },
      {
        "name": "webkit",
        "use": { ...devices["Desktop Safari"] }
      },
      {
        "name": "mobile-chrome",
        "use": { ...devices["Pixel 5"] }
      },
      {
        "name": "mobile-safari",
        "use": { ...devices["iPhone 12"] }
      },
      {
        "name": "tablet",
        "use": { ...devices["iPad Pro"] }
      }
    ],
    "webServer": {
      "command": "npm run dev",
      "url": "http://localhost:3000",
      "reuseExistingServer": !process.env.CI,
      "timeout": 120000
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.12",
    "jest": "^29.5.0",
    "jest-environment-node": "^29.5.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
