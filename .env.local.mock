# AgentFlow Pro - MOCK MODE (UI Testing Only)
# Use this for UI testing without database

# Mock database - no connection needed
MOCK_DATABASE=true
DATABASE_URL="mock://local"

# Auth - mock session
NEXTAUTH_SECRET="dev-secret-key"
NEXTAUTH_URL="http://localhost:3002"

# Disable Prisma
PRISMA_DISABLE_LOGGING=true

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Redis
REDIS_URL=""

# Sentry
SENTRY_DSN=""

# Admin
ADMIN_EMAILS=""

# Vercel
VERCEL_TOKEN=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Feature flags
NODE_ENV="development"
