{
  "mcpServers": {
    "neon": {
      "type": "http",
      "url": "https://mcp.neon.tech/mcp"
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git"
      ]
    },
    "github": {
      "url": "https://mcp.github.com",
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ]
    },
    "firecrawl": {
      "command": "npx",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@context7/mcp-server"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "vercel": {
      "command": "npx",
      "args": [
        "-y",
        "@vercel/mcp"
      ],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "@docker/mcp-server"
      ]
    },
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@sentry/mcp"
      ],
      "env": {
        "SENTRY_DSN": "${SENTRY_DSN}"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "stripe": {
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp"
      ],
      "env": {
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
      }
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis"
      ],
      "env": {
        "REDIS_URL": "${UPSTASH_REDIS_REST_URL}"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "fetch-mcp-server"
      ]
    },
    "time": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-time"
      ]
    },
    "everart": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everart"
      ],
      "env": {
        "EVERART_API_KEY": "${EVERART_API_KEY}"
      }
    },
    "cloudflare": {
      "command": "npx",
      "args": [
        "-y",
        "cloudflare-mcp"
      ],
      "env": {
        "CLOUDFLARE_API_TOKEN": "${CLOUDFLARE_API_TOKEN}",
        "CLOUDFLARE_ACCOUNT_ID": "${CLOUDFLARE_ACCOUNT_ID}"
      }
    },
    "openai": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-openai"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}"
      }
    },
    "google-ai": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-ai"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    },
    "resend": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-resend"
      ],
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}"
      }
    },
    "pusher": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-pusher"
      ],
      "env": {
        "PUSHER_APP_ID": "${PUSHER_APP_ID}",
        "PUSHER_KEY": "${PUSHER_KEY}",
        "PUSHER_SECRET": "${PUSHER_SECRET}",
        "PUSHER_CLUSTER": "${PUSHER_CLUSTER}"
      }
    },
    "qdrant": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "${QDRANT_URL}",
        "QDRANT_API_KEY": "${QDRANT_API_KEY}"
      }
    },
    "twilio": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-twilio"
      ],
      "env": {
        "TWILIO_ACCOUNT_SID": "${TWILIO_ACCOUNT_SID}",
        "TWILIO_AUTH_TOKEN": "${TWILIO_AUTH_TOKEN}",
        "TWILIO_FROM": "${TWILIO_FROM}"
      }
    },
    "slack": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "env": {
        "SLACK_TOKEN": "${SLACK_ESCALATION_WEBHOOK_URL}"
      }
    },
    "salesforce": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-salesforce"
      ],
      "env": {
        "SALESFORCE_CLIENT_ID": "${SALESFORCE_CLIENT_ID}",
        "SALESFORCE_CLIENT_SECRET": "${SALESFORCE_CLIENT_SECRET}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ],
      "env": {}
    },
    "everything": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ]
    },
    "agentflow-pro": {
      "command": "npm",
      "args": [
        "run",
        "mcp"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}",
        "UPSTASH_REDIS_REST_URL": "${UPSTASH_REDIS_REST_URL}"
      }
    }
  }
}