{
  "openapi": "3.0.3",
  "info": {
    "title": "AgentFlow Pro API",
    "description": "Multi-Agent AI Platform - Public and Workflow APIs",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "AgentFlow Pro"
    }
  ],
  "paths": {
    "/api/v1/generate": {
      "post": {
        "summary": "Generate blog content",
        "description": "Generate SEO-optimized blog content for a topic. Requires API key.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "topic"
                ],
                "properties": {
                  "topic": {
                    "type": "string",
                    "example": "How to optimize React performance"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated content",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "topic": {},
                    "title": {},
                    "content": {},
                    "keywords": {}
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "400": {
            "description": "Missing required field"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/api/workflows": {
      "get": {
        "summary": "List workflows",
        "description": "List all workflows for the authenticated user. Requires session.",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Workflows list"
          }
        }
      },
      "post": {
        "summary": "Create workflow",
        "description": "Create a new workflow. Requires session.",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {},
                  "nodes": {},
                  "edges": {},
                  "slackWebhookUrl": {},
                  "metadata": {}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created workflow"
          }
        }
      }
    },
    "/api/workflows/{id}": {
      "get": {
        "summary": "Get workflow",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "responses": {
          "200": {},
          "404": {}
        }
      },
      "put": {
        "summary": "Update workflow",
        "description": "Update workflow (name, nodes, edges, slackWebhookUrl, metadata.notificationEmail)",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {},
          "404": {}
        }
      },
      "delete": {
        "summary": "Delete workflow",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "responses": {
          "200": {},
          "404": {}
        }
      }
    },
    "/api/workflows/{id}/webhook": {
      "post": {
        "summary": "Generate webhook token",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "webhookToken"
          }
        }
      }
    },
    "/api/chat": {
      "post": {
        "summary": "Chat with AI",
        "description": "Streaming chat with optional multi-agent plan/execute. Requires session.",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messages": {
                    "type": "array"
                  },
                  "planExecute": {
                    "type": "boolean"
                  },
                  "threadId": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Streaming UIMessage response"
          }
        }
      }
    },
    "/api/chat/escalations": {
      "get": {
        "summary": "List chat escalations",
        "description": "List HITL escalations. Use ?status=pending|acknowledged|resolved|all. Admin: ?all=true for all users.",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "parameters": [
          {
            "name": "threadId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "acknowledged",
                "resolved",
                "all"
              ]
            }
          },
          {
            "name": "all",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "escalations array"
          }
        }
      }
    },
    "/api/chat/escalations/{id}": {
      "patch": {
        "summary": "Update escalation status",
        "description": "Update escalation status (pending, acknowledged, resolved). Owner or admin only.",
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "pending",
                      "acknowledged",
                      "resolved"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated escalation"
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "ok: true"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Key"
      },
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "next-auth.session-token"
      }
    }
  }
}