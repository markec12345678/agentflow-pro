# AgentFlow Pro - Environment Variables
# Copy to .env and fill in values

# Mock mode za development - agenti vrnejo mock data brez API klicev
MOCK_MODE="false"

# Database (Supabase - glej docs/database-setup.md)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Stripe (Phase 5)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# Vercel / Netlify
VERCEL_TOKEN=""
NETLIFY_TOKEN=""

# Sentry (glej docs/VERCEL-ENV-CHECKLIST.md)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Admin: comma-separated emails that can access /admin
ADMIN_EMAILS=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LinkedIn OAuth (Publish - create app at developer.linkedin.com)
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Twitter OAuth 2.0 (Publish - create app at developer.twitter.com)
TWITTER_API_KEY=""
TWITTER_API_SECRET=""

# HubSpot OAuth (create app at developers.hubspot.com)
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# Google Analytics (client-side - glej VERCEL-ENV-CHECKLIST)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Pusher (real-time Canvas - dashboard.pusher.com)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Google Search Console OAuth (uporabi iste GOOGLE_* kot za Sign-in, scope webmasters.readonly)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Meta (Facebook/Instagram) - create app at developers.facebook.com
META_APP_ID=""
META_APP_SECRET=""

# Booking.com Affiliate - optional default aid (users can set own in Settings)
# BOOKING_AFFILIATE_ID="123456"

# Optional - Agent APIs
# CONTEXT7: vstavi v .env.local | bere src/config/env.ts -> getContext7ApiKey()
# SerpAPI: API key from https://serpapi.com/manage-api-key
SERPAPI_API_KEY=""
CONTEXT7_API_KEY=""
FIRECRAWL_API_KEY=""
GITHUB_TOKEN=""
OPENAI_API_KEY=""
