# AgentFlow Pro - Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL="postgresql://localhost:5432/agentflow"

# Stripe (Phase 5)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# Vercel / Netlify
VERCEL_TOKEN=""
NETLIFY_TOKEN=""

# Sentry
SENTRY_DSN=""

# Admin (comma-separated emails for /admin access)
ADMIN_EMAILS=""

# Auth (Phase 5)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# AgentFlow Pro Core (Python) - path for tourism generate API
AGENTFLOW_CORE_PATH="C:\\Users\\admin\\AgentFlow_Pro_Core"

# Redis (optional - conversation/session cache)
REDIS_URL=""

# Salesforce (optional - CRM integration)
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""

# Qdrant (optional - vector search for semantic search, auto-indexing)
# Cloud example: https://<cluster-id>.us-east-1-1.aws.cloud.qdrant.io:6333
QDRANT_URL=""
QDRANT_API_KEY=""

# MOCK_MODE: "true" = agents return mock data without API keys (dev); "false" = real LLM calls
MOCK_MODE="true"

# LLM - OpenAI (primary) or Alibaba Qwen (fallback)
OPENAI_API_KEY=""
ALIBABA_QWEN_API_KEY=""

# Pusher (optional - real-time Canvas collaboration)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Optional - Agent APIs
BRAVE_API_KEY=""
CONTEXT7_API_KEY=""
FIRECRAWL_API_KEY=""
GITHUB_TOKEN=""
