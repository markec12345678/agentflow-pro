# =============================================================================
# AgentFlow Pro - Environment Variables Template
# Copy this file to .env.local and fill in your values
# =============================================================================
# 
# QUICK START:
# 1. Copy this file to .env.local
# 2. Fill in required values (marked with *)
# 3. Generate secrets with provided commands
# 4. Run: npm run db:migrate
#
# =============================================================================

# =============================================================================
# 🗄️ DATABASE (Required)
# =============================================================================
# PostgreSQL connection string
# For cloud (Supabase/Neon): add ?connection_limit=5&connect_timeout=15
DATABASE_URL="postgresql://user:password@localhost:5432/agentflow_pro"

# Redis (Required for Working Memory - <1ms latency)
# Options:
# 1. Upstash Redis (serverless, pay-per-use): https://upstash.com
# 2. Local Redis: redis://localhost:6379
# 3. Redis Cloud: https://redis.com/cloud
UPSTASH_REDIS_REST_URL="https://xxx.us-east-1-1.aws.cloud.upstash.io"

# Optional: Redis URL for local development
# REDIS_URL="redis://localhost:6379"

# Qdrant (optional - vector search for semantic search)
# Cloud: https://<cluster-id>.us-east-1-1.aws.cloud.qdrant.io:6333
QDRANT_URL=""
QDRANT_API_KEY=""

# =============================================================================
# 🔐 AUTHENTICATION (Required)
# =============================================================================
# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
# Must be min 32 characters
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3002"

# Google OAuth (optional - for "Sign in with Google")
# Setup: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Firebase (optional - alternative auth provider)
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_MEASUREMENT_ID=""

# Admin emails (comma-separated for /admin access)
ADMIN_EMAILS=""

# =============================================================================
# 💳 STRIPE PAYMENTS (Required for production)
# =============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_"
STRIPE_WEBHOOK_SECRET="whsec_"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_"

# Price IDs (from Stripe Dashboard → Products)
STRIPE_PRICE_STARTER="price_"
STRIPE_PRICE_PRO="price_"
STRIPE_PRICE_ENTERPRISE="price_"

# =============================================================================
# 🤖 AI AGENTS (Required when MOCK_MODE=false)
# =============================================================================
# OpenAI (primary LLM)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-"

# Google Gemini (fallback)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Alibaba Qwen (fallback)
ALIBABA_QWEN_API_KEY=""

# Agent APIs
FIRECRAWL_API_KEY="fc-"         # Web scraping (firecrawl.com)
SERPAPI_API_KEY=""               # Search (serpapi.com)
BRAVE_API_KEY=""                 # Brave Search
CONTEXT7_API_KEY=""              # API documentation
GITHUB_TOKEN="ghp_"              # GitHub API (for Code Agent)

# =============================================================================
# 📧 EMAIL & COMMUNICATION (Optional)
# =============================================================================
# Resend (email delivery)
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_"
EMAIL_FROM="AgentFlow Pro <notifications@agentflow.pro>"

# WhatsApp Business (optional - guest communication)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# Pusher (real-time Canvas collaboration)
# Get from: https://pusher.com
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# =============================================================================
# 🏨 TOURISM INTEGRATIONS (Optional)
# =============================================================================
# AJPES eTurizem (Slovenian tourism registry)
# Generate 32-byte hex: openssl rand -hex 32
AJPES_ENCRYPTION_KEY=""

# AgentFlow Core (Python) - path for tourism generate API
AGENTFLOW_CORE_PATH="C:\\Users\\admin\\AgentFlow_Pro_Core"

# Channel Integrations (Booking.com, Airbnb)
BOOKING_COM_API_KEY=""
BOOKING_COM_SECRET=""
BOOKING_COM_PROPERTY_ID=""
BOOKING_COM_ENV="test"

AIRBNB_CLIENT_ID=""
AIRBNB_CLIENT_SECRET=""
AIRBNB_REDIRECT_URI="http://localhost:3002/api/tourism/airbnb/oauth/callback"
AIRBNB_ENV="test"

# Channel settings
CHANNEL_SYNC_INTERVAL_MINUTES="15"
CHANNEL_AUTO_APPROVE="false"
CHANNEL_RATE_LIMIT_PER_MINUTE="60"
CHANNEL_ENABLE_BOOKING_COM="true"
CHANNEL_ENABLE_AIRBNB="true"
CHANNEL_ENABLE_EXPEDIA="false"
CHANNEL_WEBHOOK_SECRET=""

# Salesforce (optional - CRM)
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""

# =============================================================================
# 📊 MONITORING & DEPLOYMENT (Optional)
# =============================================================================
# Sentry (error tracking)
# Get from: https://sentry.io/settings/<org>/projects/
SENTRY_DSN=""

# Vercel / Netlify deployment tokens
VERCEL_TOKEN=""
NETLIFY_TOKEN=""

# Cron jobs (Vercel production - protects db-cleanup, pms-sync-all, email-scheduler)
CRON_SECRET=""

# =============================================================================
# ⚠️ HITL ESCALATION & SMART ALERTS (Optional)
# =============================================================================
# Slack webhook for low-confidence chat handoffs
SLACK_ESCALATION_WEBHOOK_URL=""

# Email for escalation alerts (requires RESEND_API_KEY)
ESCALATION_NOTIFY_EMAIL=""

# Smart Alerts
SMART_ALERT_RECEPTIONIST_EMAIL=""
SLACK_ALERTS_WEBHOOK_URL=""

# Twilio (SMS for director - occupancy alerts)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# =============================================================================
# 🎛️ MODE FLAGS
# =============================================================================
# MOCK_MODE: "true" = mock data (dev), "false" = real API calls (production)
MOCK_MODE="true"

# DRY_RUN: "true" = simulate without sending, "false" = real delivery
DRY_RUN="false"

# =============================================================================
# 📝 NEXT STEPS
# =============================================================================
# 1. Fill in required values above (marked with * in comments)
# 2. Run: npm run db:migrate
# 3. Run: npm run dev
# 4. Visit: http://localhost:3002
#
# For production deployment, set these in Vercel Dashboard → Settings → Environment Variables
