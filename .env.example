# AgentFlow Pro - Environment Variables
# Copy to .env and fill in values

# Database. Za cloud (Supabase, Neon) dodaj: ?connection_limit=5&connect_timeout=15
DATABASE_URL="postgresql://localhost:5432/agentflow"

# Stripe (Phase 5)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# Vercel / Netlify
VERCEL_TOKEN=""
NETLIFY_TOKEN=""

# Sentry
SENTRY_DSN=""

# Admin (comma-separated emails for /admin access)
ADMIN_EMAILS=""

# Auth (Phase 5). NEXTAUTH_URL must match dev port (3002). NEXTAUTH_SECRET min 32 chars.
NEXTAUTH_SECRET=""  # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3002"

# Google OAuth (optional – za "Sign in with Google" na login/register)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AgentFlow Pro Core (Python) - path for tourism generate API
AGENTFLOW_CORE_PATH="C:\\Users\\admin\\AgentFlow_Pro_Core"

# Redis (optional - conversation/session cache)
REDIS_URL=""

# Salesforce (optional - CRM integration)
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""

# Qdrant (optional - vector search for semantic search, auto-indexing)
# Cloud example: https://<cluster-id>.us-east-1-1.aws.cloud.qdrant.io:6333
QDRANT_URL=""
QDRANT_API_KEY=""

# MOCK_MODE: "true" = agents return mock data without API keys (dev); "false" = real LLM/agent calls
# Production: set MOCK_MODE="false" in Vercel + add API keys (OPENAI, FIRECRAWL, CONTEXT7, GITHUB_TOKEN)
MOCK_MODE="true"

# DRY_RUN: "true" = simulate email/Slack/SMS without sending (testing); "false" = real delivery
DRY_RUN="false"

# LLM - OpenAI (primary), Gemini, or Alibaba Qwen (fallback). Required when MOCK_MODE=false
# Dodaš v .env in ostane trajno – ne izgubi se
OPENAI_API_KEY=""
GEMINI_API_KEY=""   # Google AI Studio: https://aistudio.google.com/app/apikey
ALIBABA_QWEN_API_KEY=""

# Pusher (optional - real-time Canvas collaboration)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Agent APIs - required for real agent execution when MOCK_MODE=false
BRAVE_API_KEY=""
CONTEXT7_API_KEY=""
FIRECRAWL_API_KEY=""
SERPAPI_API_KEY=""   # serpapi.com/manage-api-key – search za Research agent
GITHUB_TOKEN=""

# Email - Resend (workflow notifications). Optional.
RESEND_API_KEY=""
EMAIL_FROM="AgentFlow Pro <notifications@agentflow.pro>"

# WhatsApp Business Cloud API (optional - guest communication)
# Meta Developer: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# AJPES eTurizem (prijava gostov). 32 bytes hex. Generate: openssl rand -hex 32
AJPES_ENCRYPTION_KEY=""

# Cron (Vercel production – zaščita db-cleanup, pms-sync-all, email-scheduler)
CRON_SECRET=""

# HITL Escalation notifications (optional)
# SLACK_ESCALATION_WEBHOOK_URL: Incoming Webhook URL for low-confidence chat handoffs
# ESCALATION_NOTIFY_EMAIL: Email address for escalation alerts (requires RESEND_API_KEY)
SLACK_ESCALATION_WEBHOOK_URL=""
ESCALATION_NOTIFY_EMAIL=""

# Smart Alerts (optional)
# SMART_ALERT_RECEPTIONIST_EMAIL: Falls back to ESCALATION_NOTIFY_EMAIL
# SLACK_ALERTS_WEBHOOK_URL: Falls back to SLACK_ESCALATION_WEBHOOK_URL
# TWILIO_*: Optional – SMS for director (e.g. occupancy alerts)
SMART_ALERT_RECEPTIONIST_EMAIL=""
SLACK_ALERTS_WEBHOOK_URL=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
