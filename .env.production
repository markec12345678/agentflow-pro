# =============================================================================
# AgentFlow Pro - Production Environment (Vercel)
# Copy these values to Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# =============================================================================
# 🗄️ DATABASE
# =============================================================================
# Use production database (Supabase/Neon)
DATABASE_URL="postgresql://user:password@host.region.provider.cloud.supabase.com:5432/postgres?connection_limit=5&connect_timeout=15"

# Redis (Upstash recommended for Vercel)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"

# Qdrant (optional - vector search)
QDRANT_URL="https://your-cluster.qdrant.tech"
QDRANT_API_KEY=""

# =============================================================================
# 🔐 AUTHENTICATION
# =============================================================================
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-production-secret-min-32-chars"
NEXTAUTH_URL="https://your-domain.com"

# Google OAuth (production)
GOOGLE_CLIENT_ID="your-production-google-client-id"
GOOGLE_CLIENT_SECRET="your-production-google-client-secret"

# Admin emails
ADMIN_EMAILS="admin@your-domain.com"

# =============================================================================
# 💳 STRIPE (Production)
# =============================================================================
STRIPE_SECRET_KEY="sk_live_your_live_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_live_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_your_live_publishable_key"
STRIPE_PRICE_STARTER="price_live_starter"
STRIPE_PRICE_PRO="price_live_pro"
STRIPE_PRICE_ENTERPRISE="price_live_enterprise"

# =============================================================================
# 🤖 AI AGENTS (Production)
# =============================================================================
# IMPORTANT: Set MOCK_MODE="false" for production!
MOCK_MODE="false"
DRY_RUN="false"

OPENAI_API_KEY="sk-your_production_openai_key"
GEMINI_API_KEY="your_production_gemini_key"
ALIBABA_QWEN_API_KEY=""

FIRECRAWL_API_KEY="fc-your_production_firecrawl_key"
SERPAPI_API_KEY="your_production_serpapi_key"
BRAVE_API_KEY=""
CONTEXT7_API_KEY=""
GITHUB_TOKEN="ghp_your_production_github_token"

# =============================================================================
# 📧 EMAIL (Production)
# =============================================================================
RESEND_API_KEY="re_your_production_resend_key"
EMAIL_FROM="AgentFlow Pro <noreply@your-domain.com>"

# WhatsApp Business (production)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# Pusher (production)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# =============================================================================
# 🏨 TOURISM (Production)
# =============================================================================
AJPES_ENCRYPTION_KEY="your_production_32_byte_hex_key"

# Channel Integrations (production)
BOOKING_COM_API_KEY=""
BOOKING_COM_SECRET=""
BOOKING_COM_PROPERTY_ID=""
BOOKING_COM_ENV="production"

AIRBNB_CLIENT_ID=""
AIRBNB_CLIENT_SECRET=""
AIRBNB_REDIRECT_URI="https://your-domain.com/api/tourism/airbnb/oauth/callback"
AIRBNB_ENV="production"

CHANNEL_SYNC_INTERVAL_MINUTES="15"
CHANNEL_AUTO_APPROVE="false"
CHANNEL_RATE_LIMIT_PER_MINUTE="60"
CHANNEL_ENABLE_BOOKING_COM="true"
CHANNEL_ENABLE_AIRBNB="true"
CHANNEL_ENABLE_EXPEDIA="false"
CHANNEL_WEBHOOK_SECRET=""

SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""

# =============================================================================
# 📊 MONITORING (Production)
# =============================================================================
SENTRY_DSN="https://your-sentry-dsn"
CRON_SECRET="your_production_cron_secret"

# Vercel deployment (managed by Vercel, no need to set)
# VERCEL_TOKEN=""

# =============================================================================
# ⚠️ HITL & ALERTS (Production)
# =============================================================================
SLACK_ESCALATION_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
ESCALATION_NOTIFY_EMAIL="support@your-domain.com"
SMART_ALERT_RECEPTIONIST_EMAIL="receptionist@your-domain.com"
SLACK_ALERTS_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/ALERT/WEBHOOK"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# =============================================================================
# 🎛️ PRODUCTION FLAGS
# =============================================================================
# CRITICAL: These must be set for production!
MOCK_MODE="false"
DRY_RUN="false"
NODE_ENV="production"
