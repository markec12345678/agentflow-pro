# Production Environment Variables for Vercel

# Database - Add your Neon/Supabase URL
DATABASE_URL="postgresql://user:password@host:5432/database?connection_limit=5&connect_timeout=15"

# Required
MOCK_MODE="false"
NODE_ENV="production"
RUST_ENABLED="false"

# Auth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-random-32-char-secret"
NEXTAUTH_URL="https://agentflow-pro.vercel.app"

# Optional - Add when ready
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
SENTRY_DSN=""
QDRANT_URL=""
QDRANT_API_KEY=""
REDIS_URL=""
