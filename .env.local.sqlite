# AgentFlow Pro - Local Development with SQLite
# Use SQLite for simple local testing (no database server needed)

# SQLite database (file-based, no server needed!)
DATABASE_URL="file:./dev.db"

# Auth
NEXTAUTH_SECRET="dev-secret-key-change-in-production-12345678"
NEXTAUTH_URL="http://localhost:3002"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Redis
REDIS_URL=""

# Sentry
SENTRY_DSN=""

# Admin
ADMIN_EMAILS=""

# Vercel
VERCEL_TOKEN=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Feature flags
NODE_ENV="development"
