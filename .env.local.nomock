# AgentFlow Pro - NO DATABASE MODE (UI Testing Only)
# This will let you test UI without database connection
# NOT for production - only for development/testing

# Mock database - no connection needed
DATABASE_URL="mock://local"

# Auth
NEXTAUTH_SECRET="dev-secret-key-change-in-production-12345678"
NEXTAUTH_URL="http://localhost:3002"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Redis
REDIS_URL=""

# Sentry
SENTRY_DSN=""

# Admin
ADMIN_EMAILS=""

# Vercel
VERCEL_TOKEN=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Feature flags
NODE_ENV="development"

# Enable mock mode
MOCK_DATABASE="true"
