{
  "installCommand": "npm install",
  "buildCommand": "npm run build:vercel",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["fra1"],
  "env": {
    "MOCK_MODE": "true",
    "NODE_ENV": "production"
  },
  "build": {
    "env": {
      "MOCK_MODE": "true"
    }
  },
  "crons": [
    {
      "path": "/api/tourism/email-scheduler",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/db-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/property-pricing-check",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/pms-sync-all",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/eturizem-reminder",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/smart-alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/smart-alerts-errors",
      "schedule": "0 5 * * *"
    }
  ]
}
