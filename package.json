{
  "name": "agentflow-pro",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='.next';fs.existsSync(p)&&fs.rmSync(p,{recursive:true});console.log('Cleaned .next')\"",
    "dev": "next dev -p 3002",
    "build": "next build",
    "build:vercel": "prisma db push --force-reset --accept-data-loss && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint . --max-warnings 999",
    "db:generate": "prisma generate",
    "db:push": "node scripts/db-push.js",
    "db:migrate": "node scripts/migrate-dev.js",
    "db:migrate:deploy": "node scripts/migrate-deploy.js",
    "db:seed": "prisma db seed",
    "db:check": "node scripts/check-database.js",
    "test": "jest",
    "test:api": "jest tests/api",
    "test:tourism": "jest tests/tourism tests/api/tourism tests/lib/tourism",
    "test:e2e": "playwright test",
    "test:e2e:tourism": "playwright test tests/e2e/tourism tests/e2e/tourism-email tests/e2e/tourism-journey tests/e2e/copy-buttons --project=chromium",
    "test:e2e:checklist": "playwright test workflow-builder --project=chromium",
    "verify:production-env": "node scripts/verify-production-env.js",
    "predeploy": "node scripts/predeploy.js",
    "test:e2e:smoke": "playwright test smoke-checklist --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:agents": "npx tsx scripts/test-agents.ts",
    "test:helpers": "npx tsx scripts/test-publish-helpers.ts",
    "audit:features": "npx tsx scripts/audit-features.ts",
    "playwright:install": "playwright install --with-deps chromium",
    "capture:login": "node scripts/capture-page-screenshot.js http://localhost:3002/login",
    "capture:page": "node scripts/capture-page-screenshot.js",
    "precommit": "bash scripts/pre-commit.sh",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:test": "k6 run load-tests/load.js",
    "load:100": "k6 run --vus 100 --duration 2m load-tests/load.js",
    "deploy": "npx vercel",
    "deploy:prod": "npx vercel --prod"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.29",
    "@ai-sdk/react": "^3.0.92",
    "@langchain/core": "^1.1.27",
    "@langchain/langgraph": "^1.1.5",
    "@prisma/client": "^6.0.0",
    "@qdrant/qdrant-js": "^1.17.0",
    "@sentry/nextjs": "^10.39.0",
    "@sentry/node": "^10.39.0",
    "@xyflow/react": "^12.0.0",
    "ai": "^6.0.86",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "mrz": "^5.0.1",
    "next": "^15.0.0",
    "next-auth": "^4.24.13",
    "octokit": "^4.0.0",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "^19.0.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "soap": "^1.7.1",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.8",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.24",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jest": "^29.0.0",
    "postcss": "^8.5.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vercel": "^50.25.1"
  }
}