{
  "name": "agentflow-pro",
  "version": "1.0.0",
  "private": true,
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:vercel": "prisma migrate deploy && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "prisma generate",
    "db:push": "node scripts/db-push.js",
    "db:migrate": "node scripts/migrate-dev.js",
    "db:migrate:deploy": "node scripts/migrate-deploy.js",
    "db:seed": "prisma db seed",
    "db:check": "node scripts/check-database.js",
    "test": "jest",
    "test:api": "jest tests/api",
    "test:tourism": "jest tests/tourism tests/api/tourism tests/lib/tourism",
    "test:e2e": "playwright test",
    "test:e2e:tourism": "playwright test tests/e2e/tourism tests/e2e/tourism-email tests/e2e/tourism-journey tests/e2e/copy-buttons --project=chromium",
    "test:e2e:checklist": "playwright test workflow-builder --project=chromium",
    "verify:production-env": "node scripts/verify-production-env.js",
    "predeploy": "node scripts/predeploy.js",
    "test:e2e:smoke": "playwright test smoke-checklist --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:agents": "npx tsx scripts/test-agents.ts",
    "test:helpers": "npx tsx scripts/test-publish-helpers.ts",
    "audit:features": "npx tsx scripts/audit-features.ts",
    "playwright:install": "playwright install --with-deps chromium",
    "precommit": "bash scripts/pre-commit.sh"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.29",
    "@ai-sdk/react": "^3.0.92",
    "@prisma/client": "^6.0.0",
    "@sentry/nextjs": "^10.39.0",
    "@sentry/node": "^10.39.0",
    "@xyflow/react": "^12.0.0",
    "ai": "^6.0.86",
    "bcrypt": "^5.1.1",
    "googleapis": "^171.4.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.13",
    "octokit": "^4.0.0",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.8",
    "zustand": "^4.5.7",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.24",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "jest": "^29.0.0",
    "postcss": "^8.5.6",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}