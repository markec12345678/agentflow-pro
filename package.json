{
  "name": "agentflow-pro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='.next';fs.existsSync(p)&&fs.rmSync(p,{recursive:true});console.log('Cleaned .next')\"",
    "dev": "npm run build:bindings:skip && next dev -p 3002",
    "build:bindings": "npm run build:bindings:pricing && npm run build:bindings:workflow",
    "build:bindings:pricing": "cd rust/pricing-engine && napi build --platform --release",
    "build:bindings:workflow": "cd rust/workflow-executor && napi build --platform --release",
    "build:bindings:pricing:debug": "cd rust/pricing-engine && napi build --platform",
    "build:bindings:workflow:debug": "cd rust/workflow-executor && napi build --platform",
    "build:bindings:skip": "echo Skipping NAPI build - using existing binary",
    "build": "npm run build:bindings:skip && next build",
    "build:vercel": "npm run build:rust && npm run build:bindings && next build",
    "build:rust": "cd rust && cargo build --workspace --release",
    "build:rust:dev": "cd rust && cargo build --workspace",
    "build:rust:all": "npm run build:rust && npm run build:bindings",
    "build:rust:workflow": "cd rust/workflow-executor && cargo build --release",
    "build:rust:pricing": "cd rust/pricing-engine && cargo build --release",
    "build:napi": "npm run build:bindings",
    "build:napi:pricing": "npm run build:bindings:pricing",
    "build:napi:workflow": "npm run build:bindings:workflow",
    "bench:ts": "npx tsx benchmarks/pricing-benchmark.ts",
    "bench": "npm run build:rust && npm run bench:ts",
    "postinstall": "prisma generate",
    "start": "next start -p 3002",
    "lint": "eslint . --max-warnings 999",
    "db:generate": "prisma generate",
    "db:push": "node scripts/db-push.js",
    "db:migrate": "node scripts/migrate-dev.js",
    "db:migrate:deploy": "node scripts/migrate-deploy.js",
    "db:seed": "prisma db seed",
    "db:check": "npx tsx scripts/check-database.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/",
    "test:integration": "vitest run tests/hotel-management.test.js",
    "test:api": "vitest run tests/api",
    "test:tourism": "vitest run tests/tourism tests/api/tourism tests/lib/tourism",
    "test:e2e": "playwright test",
    "test:e2e:hotel": "python tests/hotel-management-tests.py",
    "test:e2e:tourism": "playwright test tests/e2e/tourism tests/e2e/tourism-email tests/e2e/tourism-journey tests/e2e/copy-buttons --project=chromium",
    "test:e2e:checklist": "playwright test workflow-builder --project=chromium",
    "test:napi": "node tests/napi-integration.test.js",
    "test:rust": "cd rust && cargo test --workspace",
    "verify:production-env": "node scripts/verify-production-env.js",
    "check-links": "node scripts/check-links.js",
    "predeploy": "node scripts/predeploy.js",
    "test:e2e:smoke": "playwright test smoke-checklist --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:agents": "npx tsx scripts/test-agents.ts",
    "test:helpers": "npx tsx scripts/test-publish-helpers.ts",
    "audit:features": "npx tsx scripts/audit-features.ts",
    "playwright:install": "playwright install --with-deps chromium",
    "capture:login": "node scripts/capture-page-screenshot.js http://localhost:3002/login",
    "capture:page": "node scripts/capture-page-screenshot.js",
    "precommit": "node scripts/pre-commit.js",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:test": "k6 run load-tests/load.js",
    "load:100": "k6 run --vus 100 --duration 2m load-tests/load.js",
    "deploy": "npx vercel",
    "deploy:prod": "npx vercel --prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/react": "^3.0.137",
    "@composio/core": "^0.6.6",
    "@composio/vercel": "^0.6.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@huggingface/inference": "^4.13.15",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@qdrant/qdrant-js": "^1.17.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.45.0",
    "@sentry/node": "^10.39.0",
    "@types/axios": "^0.14.4",
    "@types/bull": "^3.15.9",
    "@types/geoip-lite": "^1.4.4",
    "@types/ioredis": "^5.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/puppeteer": "^5.4.7",
    "@types/recharts": "^1.8.29",
    "@types/socket.io": "^3.0.2",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@vercel/analytics": "^1.6.1",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.116",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "geoip-lite": "^2.0.1",
    "googleapis": "^171.4.0",
    "ical.js": "^2.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "ml-matrix": "^6.12.1",
    "mrz": "^5.0.2",
    "next": "^15.0.0",
    "next-auth": "^4.24.13",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.13",
    "octokit": "^4.0.0",
    "pg": "^8.20.0",
    "puppeteer": "^24.40.0",
    "pusher": "^5.3.3",
    "pusher-js": "^8.4.3",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.0.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "redis": "^5.11.0",
    "sentiment": "^5.0.2",
    "soap": "^1.8.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.1.8",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vercel": "^50.35.0",
    "vitest": "^3.0.0"
  },
  "napi": {
    "name": "agentflow-rust-bindings",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-pc-windows-msvc",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    },
    "npmDir": "./npm"
  }
}