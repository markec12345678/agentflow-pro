{
  "manifest_version": 3,
  "name": "AgentFlow Pro",
  "version": "1.0.0",
  "description": "Generate content in context. Select text and create blog posts, social copy, or emails with AgentFlow Pro.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:*/*"
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
}