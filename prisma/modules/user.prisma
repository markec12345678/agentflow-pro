// User Domain Models
// Includes: User, auth, roles, teams, profiles

enum UserRole {
  ADMIN
  DIRECTOR
  MANAGER
  VIEWER
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String?
  passwordHash            String?
  trialEndsAt             DateTime?
  activeTeamId            String?
  activePropertyId        String?
  role                    UserRole  @default(VIEWER)
  aiQuota                 Int       @default(100)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  emailVerified           DateTime?
  image                   String?
  alertConfiguration      Json?
  eturizemConfig          Json?
  stripeConfig            Json?
  notificationPreferences Json?
  
  // Relations
  accounts                Account[]
  blogPosts               BlogPost[]
  sessions                Session[]
  subscription            Subscription?
  alertEvents             AlertEvent[]
  chatEscalations         ChatEscalation[]
  contentHistory          ContentHistory[]
  conversationThreads     ConversationThread[]
  itineraries             Itinerary[]
  notifications           Notification[]
  teamMembers             TeamMember[]
  ownedTeams              Team[]       @relation("TeamOwner")
  translationJobs         TranslationJob[]
  usageAlerts             UsageAlert[]
  userTemplates           UserTemplate[]
  workflows               Workflow[]
  properties              Property[]   @relation("PropertyToUser")
  branding                Branding?
  customRoles             CustomRole[]
  sentMessages            Message[]    @relation("MessageSender")
  receivedMessages        Message[]    @relation("MessageRecipient")
  messageGroups           MessageGroupMember[]
  ownerProfile            Owner?
  guestPreferences        GuestPreference[] @relation("UserPreferences")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model UsageAlert {
  id          String   @id @default(cuid())
  userId      String
  type        String
  threshold   Int
  current     Int      @default(0)
  max         Int
  isTriggered Boolean  @default(false)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("usage_alerts")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Team {
  id             String       @id @default(cuid())
  name           String
  ownerId        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  campaignBoards CampaignBoard[]
  invites        Invite[]
  members        TeamMember[]
  owner          User         @relation("TeamOwner", fields: [ownerId], references: [id])
  workspaces     Workspace[]

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  userId     String
  role       String   @default("member")
  joinedAt   DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("team_members")
}

model Invite {
  id         String   @id @default(cuid())
  teamId     String
  email      String
  role       String
  status     String   @default("pending")
  expiresAt  DateTime
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("invites")
}

model Workspace {
  id             String       @id @default(cuid())
  teamId         String
  name           String
  type           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  campaignBoards CampaignBoard[]
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("workspaces")
}

model CampaignBoard {
  id             String   @id @default(cuid())
  teamId         String?
  workspaceId    String?
  name           String
  description    String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  team           Team?    @relation(fields: [teamId], references: [id])
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([teamId])
  @@index([workspaceId])
  @@map("campaign_boards")
}
