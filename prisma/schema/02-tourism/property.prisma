// =============================================================================
// Property Management
// Hotels, resorts, apartments, camps - all property types
// =============================================================================

model Property {
  id                           String               @id @default(cuid())
  userId                       String?
  ownerId                      String?
  name                         String
  location                     String?
  type                         String?              // hotel, resort, apartment, camp, farm
  capacity                     Int?
  description                  String?
  basePrice                    Float?
  currency                     String?              @default("EUR")
  seasonRates                  Json?
  pricingRules                 Json?
  reservationAutoApprovalRules Json?
  rnoId                        Int?
  googlePlaceId                String?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  eturizemId                   String?
  eturizemSyncStatus           String?              @default("not_mapped")
  eturizemSyncedAt             DateTime?
  eturizemLastError            String?
  
  // Relations
  ajpesConnection              AjpesConnection?
  owner                        Owner?               @relation(fields: [ownerId], references: [id])
  alertEvents                  AlertEvent[]
  amenities                    Amenity[]
  blockedDates                 BlockedDate[]
  competitors                  Competitor[]
  employees                    Employee[]
  faqResponseLogs              FaqResponseLog[]
  communications               GuestCommunication[]
  guests                       Guest[]
  housekeepingTasks            HousekeepingTask[]
  inquiries                    Inquiry[]
  landingPages                 LandingPage[]
  pmsConnections               PmsConnection[]
  policies                     PropertyPolicy[]
  reservations                 Reservation[]
  reviews                      Review[]
  rooms                        Room[]
  seoMetrics                   SeoMetric[]
  staffAssignments             StaffAssignment[]
  userTemplates                UserTemplate[]
  workflows                    Workflow[]
  pageDesigns                  PageDesign[]         @relation("PageDesignProperties")
  users                        User[]               @relation("PropertyToUser")
  invoices                     Invoice[]            @relation("PropertyInvoices")
  revenueSplits                RevenueSplit[]
  staffSchedules               StaffSchedule[]
  sustainabilityMetrics        SustainabilityMetric[]
  ecoPractices                 EcoPractice[]
  ecoCertifications            EcoCertification[]
  photoAnalyses                PhotoAnalysis[]
  taskCollaborations           TaskCollaboration[]
  performanceMetrics           PerformanceMetric[]

  @@map("properties")
}

model Owner {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String?
  company         String?
  taxId           String?
  address         String?
  city            String?
  postalCode      String?
  country         String?   @default("Slovenia")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  properties      Property[]

  @@index([email])
  @@map("owners")
}

model Amenity {
  id          String    @id @default(cuid())
  propertyId  String
  name        String
  category    String?   // wellness, dining, sports, business, other
  description String?
  icon        String?
  createdAt   DateTime  @default(now())
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("amenities")
}

model BlockedDate {
  id          String    @id @default(cuid())
  propertyId  String
  roomId      String?
  date        DateTime
  reason      String?   // maintenance, overbooked, closed
  notes       String?
  createdAt   DateTime  @default(now())
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room        Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([propertyId, date])
  @@index([roomId, date])
  @@map("blocked_dates")
}

model Competitor {
  id          String    @id @default(cuid())
  propertyId  String
  name        String
  url         String?
  location    String?
  rating      Float?
  priceRange  String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("competitors")
}

model Employee {
  id          String    @id @default(cuid())
  propertyId  String
  name        String
  email       String?
  phone       String?
  position    String
  department  String?
  hireDate    DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("employees")
}

model PropertyPolicy {
  id          String    @id @default(cuid())
  propertyId  String
  type        String    // cancellation, checkin, checkout, house_rules, pet_policy
  title       String
  content     String
  language    String    @default("sl")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, type])
  @@map("property_policies")
}

model FaqResponseLog {
  id              String    @id @default(cuid())
  propertyId      String
  question        String
  answer          String
  language        String    @default("sl")
  confidenceScore Float?
  source          String?   // manual, ai-generated
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("faq_response_logs")
}
