generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  passwordHash     String?
  trialEndsAt      DateTime?
  activePropertyId String?
  blogPosts        BlogPost[]
  subscription     Subscription?
  workflows        Workflow[]
  landingPages     LandingPage[]
  properties       Property[]
  seoMetrics       SeoMetric[]
  translationJobs  TranslationJob[]
  userTemplates    UserTemplate[]
}

model BlogPost {
  id              String   @id @default(cuid())
  userId          String
  title           String?
  topic           String?
  createdAt       DateTime @default(now())
  fullContent     String?
  metaTitle       String?
  metaDescription String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workflow {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nodes     Json     @default("[]")
  edges     Json     @default("[]")
  metadata  Json?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id         String   @id @default(cuid())
  userId     String?
  agentType  String
  workflowId String?
  status     String
  input      Json?
  output     Json?
  createdAt  DateTime @default(now())
}

model Onboarding {
  id                String   @id @default(cuid())
  industry          String?
  companySize       String?
  workType          String?
  role              String?
  workspaceName     String?
  blogUrl           String?
  brandVoiceSummary String?
  styleGuide        String?
  visualGuidelines  String?
  audiences         Json?
  companyKnowledge  Json?
  userId            String?
  createdAt         DateTime @default(now())
}

model UserTemplate {
  id         String    @id @default(cuid())
  userId     String
  name       String
  category   String
  basePrompt String
  customVars Json?
  content    String?
  language   String?
  isPublic   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([propertyId])
  @@map("user_templates")
}

model LandingPage {
  id             String    @id @default(cuid())
  userId         String
  title          String
  slug           String?   @unique
  content        Json
  template       String    @default("tourism-basic")
  languages      String[]
  isPublished    Boolean   @default(false)
  publishedUrl   String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPublished])
  @@index([propertyId])
  @@map("landing_pages")
}

model Property {
  id            String         @id @default(cuid())
  userId        String
  name          String
  location      String?
  type          String?
  capacity      Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  landingPages  LandingPage[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userTemplates UserTemplate[]

  @@index([userId])
  @@map("properties")
}

model SeoMetric {
  id           String    @id @default(cuid())
  userId       String
  contentId    String?
  contentType  String
  keyword      String
  position     Int?
  searchVolume Int?
  difficulty   Int?
  lastChecked  DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType, keyword])
  @@map("seo_metrics")
}

model TranslationJob {
  id            String    @id @default(cuid())
  userId        String
  sourceContent String
  sourceLang    String    @default("sl")
  targetLangs   String[]
  status        String    @default("pending")
  results       Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("translation_jobs")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  plan      String?
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
