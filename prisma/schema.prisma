generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Template Usage Tracking
model TemplateUsage {
  id             String   @id @default(cuid())
  templateId     String
  system         String
  count          Int      @default(0)
  lastUsed       DateTime @updatedAt
  totalRenderTime Int     @default(0)
  errorCount     Int      @default(0)

  @@unique([templateId, system])
  @@index([system])
  @@index([lastUsed])
  @@map("template_usage")
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  name                     String?
  passwordHash             String?
  trialEndsAt              DateTime?
  activeTeamId             String?
  activePropertyId         String?
  role                     UserRole                  @default(VIEWER)
  aiQuota                  Int                       @default(100)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  emailVerified            DateTime?
  image                    String?
  alertConfiguration       Json?
  eturizemConfig           Json?
  stripeConfig             Json?
  sendGridConfig           Json?
  sentryConfig             Json?
  githubConfig             Json?
  vercelConfig             Json?
  firecrawlConfig          Json?
  notificationPreferences  Json?
  accounts                 Account[]
  blogPosts                BlogPost[]
  projects                 Project[]
  sessions                 Session[]
  subscription             Subscription?
  alertEvents              AlertEvent[]
  campaignBoards           CampaignBoard[]
  chatEscalations          ChatEscalation[]
  contentHistory           ContentHistory[]
  conversationThreads      ConversationThread[]
  itineraries              Itinerary[]
  landingPages             LandingPage[]
  notifications            Notification[]
  pageDesigns              PageDesign[]
  searchConsoleConnections SearchConsoleConnection[]
  seoMetrics               SeoMetric[]
  teamMembers              TeamMember[]
  ownedTeams               Team[]                    @relation("TeamOwner")
  translationJobs          TranslationJob[]
  usageAlerts              UsageAlert[]
  userTemplates            UserTemplate[]
  workflows                Workflow[]
  properties               Property[]                @relation("PropertyToUser")

  @@map("users")
}

model BlogPost {
  id              String    @id @default(cuid())
  userId          String
  title           String?
  topic           String?
  fullContent     String?
  metaTitle       String?
  metaDescription String?
  imageUrl        String?
  pipelineStage   String?   @default("draft")
  brief           String?
  reviewedAt      DateTime?
  guardrailIssues Json?
  approvedBy      String?
  approvalStatus  String?   @default("pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageAlert {
  id          String    @id @default(cuid())
  userId      String
  type        String
  threshold   Int
  current     Int       @default(0)
  max         Int
  isTriggered Boolean   @default(false)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("usage_alerts")
}

model SmartAlertLog {
  id          String    @id @default(cuid())
  eventType   String
  entityId    String
  channel     String
  sentAt      DateTime  @default(now())
  escalatedAt DateTime?
  escalatedTo String?

  @@index([eventType, entityId, sentAt])
  @@map("smart_alert_logs")
}

model AlertRule {
  id                   String   @id @default(cuid())
  name                 String
  eventType            String
  threshold            Float?
  severity             String   @default("medium")
  enabled              Boolean  @default(true)
  channels             String[] @default(["email"])
  cooldownMinutes      Int      @default(60)
  escalateAfterMinutes Int?
  escalateTo           String?
  createdBy            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([eventType, enabled])
  @@map("alert_rules")
}

model AlertEvent {
  id             String    @id @default(cuid())
  type           String    @default("system_error")
  title          String
  message        String
  severity       String    @default("medium")
  status         String    @default("active")
  userId         String?
  propertyId     String?
  metadata       Json?
  acknowledgedBy String?
  acknowledgedAt DateTime?
  dismissedBy    String?
  dismissedAt    DateTime?
  createdAt      DateTime  @default(now())
  property       Property? @relation(fields: [propertyId], references: [id])
  user           User?     @relation(fields: [userId], references: [id])

  @@index([type, severity, status])
  @@index([userId, createdAt])
  @@index([propertyId, createdAt])
  @@map("alert_events")
}

model Workflow {
  id              String               @id @default(cuid())
  name            String
  description     String?
  userId          String
  propertyId      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  nodes           Json                 @default("[]")
  edges           Json                 @default("[]")
  metadata        Json?
  webhookToken    String?              @unique
  slackWebhookUrl String?
  status          String               @default("draft")
  agentId         String?
  checkpoints     WorkflowCheckpoint[]
  executions      WorkflowExecution[]
  agent           Agent?               @relation(fields: [agentId], references: [id])
  property        Property?            @relation(fields: [propertyId], references: [id])
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@map("workflows")
}

model WorkflowCheckpoint {
  id              String    @id @default(cuid())
  workflowId      String
  nodeId          String
  nodeLabel       String?
  contextSnapshot Json
  status          String
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
}

model AgentRun {
  id              String   @id @default(cuid())
  userId          String?
  agentType       String
  workflowId      String?
  status          String
  input           Json?
  output          Json?
  creditsConsumed Int      @default(3)
  model           String?
  inputTokens     Int?
  outputTokens    Int?
  costEst         Float?
  latencyMs       Int?
  createdAt       DateTime @default(now())
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  value     String
  createdAt DateTime @default(now())

  @@unique([userId, provider])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String
  name      String?
  createdAt DateTime @default(now())

  @@index([keyHash])
  @@index([userId])
}

model Onboarding {
  id                String   @id @default(cuid())
  industry          String?
  companySize       String?
  workType          String?
  role              String?
  workspaceName     String?
  blogUrl           String?
  brandVoiceSummary String?
  styleGuide        String?
  visualGuidelines  String?
  audiences         Json?
  companyKnowledge  Json?
  userId            String?
  createdAt         DateTime @default(now())
}

model UserTemplate {
  id         String    @id @default(cuid())
  userId     String
  propertyId String?
  name       String
  category   String
  basePrompt String
  customVars Json?
  content    String?
  language   String?
  isPublic   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  property   Property? @relation(fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([propertyId])
  @@map("user_templates")
}

model LandingPage {
  id             String    @id @default(cuid())
  userId         String
  title          String
  slug           String?   @unique
  content        Json
  template       String    @default("tourism-basic")
  languages      String[]
  isPublished    Boolean   @default(false)
  publishedUrl   String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPublished])
  @@index([propertyId])
  @@map("landing_pages")
}

model Property {
  id                           String               @id @default(cuid())
  userId                       String?
  name                         String
  location                     String?
  type                         String?
  capacity                     Int?
  description                  String?
  basePrice                    Float?
  currency                     String?              @default("EUR")
  seasonRates                  Json?
  pricingRules                 Json?
  reservationAutoApprovalRules Json?
  rnoId                        Int?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  eturizemId                   String?
  eturizemSyncStatus           String?              @default("not_mapped")
  eturizemSyncedAt             DateTime?
  eturizemLastError            String?
  ajpesConnection              AjpesConnection?
  alertEvents                  AlertEvent[]
  amenities                    Amenity[]
  blockedDates                 BlockedDate[]
  competitors                  Competitor[]
  faqResponseLogs              FaqResponseLog[]
  communications               GuestCommunication[]
  guests                       Guest[]
  inquiries                    Inquiry[]
  itineraries                  Itinerary[]
  landingPages                 LandingPage[]
  pmsConnections               PmsConnection[]
  policies                     PropertyPolicy[]
  reservations                 Reservation[]
  reviews                      Review[]
  rooms                        Room[]
  seoMetrics                   SeoMetric[]
  userTemplates                UserTemplate[]
  workflows                    Workflow[]
  pageDesigns                  PageDesign[]         @relation("PageDesignProperties")
  users                        User[]               @relation("PropertyToUser")

  @@map("properties")
}

model Review {
  id             String       @id @default(cuid())
  propertyId     String
  reservationId  String?      @unique
  guestId        String?
  rating         Float
  title          String?
  content        String
  platform       String       @default("direct")
  status         String       @default("pending")
  sentiment      String?
  sentimentScore Float?
  response       String?
  respondedAt    DateTime?
  respondedBy    String?
  categories     Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  guest          Guest?       @relation(fields: [guestId], references: [id])
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation    Reservation? @relation(fields: [reservationId], references: [id])

  @@index([propertyId, status])
  @@index([platform])
  @@map("reviews")
}

model Room {
  id           String        @id @default(cuid())
  propertyId   String
  name         String
  type         String
  capacity     Int
  beds         Int?
  description  String?
  basePrice    Float?
  amenities    String[]
  photos       String[]
  seasonRates  Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  blockedDates BlockedDate[]
  reservations Reservation[]
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("rooms")
}

model AjpesConnection {
  id          String   @id @default(cuid())
  propertyId  String   @unique
  username    String
  passwordEnc String
  rnoId       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("ajpes_connections")
}

model PmsConnection {
  id          String   @id @default(cuid())
  propertyId  String
  provider    String
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, provider])
  @@index([propertyId])
  @@map("pms_connections")
}

model Itinerary {
  id         String    @id @default(cuid())
  userId     String
  propertyId String?
  title      String
  days       Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  property   Property? @relation(fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@map("itineraries")
}

model SeoMetric {
  id           String    @id @default(cuid())
  userId       String
  propertyId   String?
  contentId    String?
  contentType  String
  keyword      String
  position     Int?
  searchVolume Int?
  difficulty   Int?
  clicks       Int?
  impressions  Int?
  date         DateTime?
  lastChecked  DateTime?
  property     Property? @relation(fields: [propertyId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType, keyword])
  @@index([propertyId, date])
  @@map("seo_metrics")
}

model TranslationJob {
  id            String    @id @default(cuid())
  userId        String
  sourceContent String
  sourceLang    String    @default("sl")
  targetLangs   String[]
  status        String    @default("pending")
  results       Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("translation_jobs")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  plan      String?
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Team {
  id             String          @id @default(cuid())
  name           String
  ownerId        String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  campaignBoards CampaignBoard[]
  invites        Invite[]
  members        TeamMember[]
  owner          User            @relation("TeamOwner", fields: [ownerId], references: [id])
  workspaces     Workspace[]

  @@index([ownerId])
  @@map("teams")
}

model Workspace {
  id             String          @id @default(cuid())
  teamId         String
  name           String
  type           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  campaignBoards CampaignBoard[]
  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("workspaces")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
  @@index([teamId])
  @@map("team_members")
}

model CampaignBoard {
  id          String     @id @default(cuid())
  name        String
  teamId      String
  workspaceId String?
  userId      String
  data        Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  team        Team       @relation(fields: [teamId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([teamId])
  @@index([userId])
  @@index([workspaceId])
  @@map("campaign_boards")
}

model Invite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([teamId])
  @@map("invites")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model ConversationThread {
  id             String               @id @default(cuid())
  userId         String
  parentThreadId String?
  messages       Json                 @default("[]")
  title          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  escalations    ChatEscalation[]
  parentThread   ConversationThread?  @relation("ThreadBranches", fields: [parentThreadId], references: [id])
  branches       ConversationThread[] @relation("ThreadBranches")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentThreadId])
  @@map("conversation_threads")
}

model ChatEscalation {
  id                 String              @id @default(cuid())
  userId             String
  threadId           String?
  lastMessagePreview String
  confidence         Float
  status             String              @default("pending")
  createdAt          DateTime            @default(now())
  thread             ConversationThread? @relation(fields: [threadId], references: [id])
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threadId])
  @@index([status])
  @@map("chat_escalations")
}

model Agent {
  id          String     @id @default(uuid())
  name        String
  description String?
  role        String     @default("assistant")
  status      String     @default("active")
  avatar      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  projects    Project[]
  workflows   Workflow[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  html        String
  css         String?
  js          String?
  agentId     String
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agent       Agent    @relation(fields: [agentId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Reservation {
  id                  String    @id @default(cuid())
  propertyId          String
  guestId             String?
  roomId              String?
  checkIn             DateTime
  checkOut            DateTime
  status              String    @default("confirmed")
  channel             String?
  totalPrice          Float?
  deposit             Float?
  touristTax          Float?
  guests              Int?
  notes               String?
  checkInToken        String?   @unique
  eturizemSubmittedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  payments            Payment[]
  guest               Guest?    @relation(fields: [guestId], references: [id])
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room                Room?     @relation(fields: [roomId], references: [id])
  review              Review?

  @@index([propertyId, checkIn])
  @@index([status])
  @@map("reservations")
}

model Payment {
  id            String      @id @default(cuid())
  reservationId String
  type          String
  amount        Float
  currency      String      @default("EUR")
  paidAt        DateTime    @default(now())
  method        String?
  notes         String?
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
  @@map("payments")
}

model Guest {
  id             String               @id @default(cuid())
  propertyId     String?
  name           String
  email          String?
  phone          String?
  dateOfBirth    DateTime?
  countryCode    String?
  documentType   String?
  documentId     String?
  gender         String?
  riskScore      String?
  isVip          Boolean              @default(false)
  gdprConsent    Boolean              @default(false)
  preferences    String?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  communications GuestCommunication[]
  property       Property?            @relation(fields: [propertyId], references: [id])
  reservations   Reservation[]
  reviews        Review[]

  @@index([propertyId])
  @@map("guests")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  title      String
  message    String
  type       String
  read       Boolean  @default(false)
  link       String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([propertyId])
  @@map("notifications")
}

model ContentHistory {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  content    String
  type       String
  status     String
  promptType String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, propertyId, type])
  @@map("content_history")
}

model SearchConsoleConnection {
  id           String    @id @default(cuid())
  userId       String
  propertyId   String?
  siteUrl      String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  lastSync     DateTime?
  status       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, siteUrl])
  @@index([propertyId])
  @@map("search_console_connections")
}

model Competitor {
  id         String            @id @default(cuid())
  propertyId String
  name       String
  url        String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  prices     CompetitorPrice[]
  property   Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("competitors")
}

model CompetitorPrice {
  id           String     @id @default(cuid())
  competitorId String
  date         DateTime
  price        Float
  roomType     String?
  createdAt    DateTime   @default(now())
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId, date])
  @@map("competitor_prices")
}

model FaqResponseLog {
  id             String    @id @default(cuid())
  question       String
  responseTimeMs Int
  confidence     Float
  propertyId     String?
  createdAt      DateTime  @default(now())
  property       Property? @relation(fields: [propertyId], references: [id])
  inquiry        Inquiry?

  @@index([propertyId, createdAt])
  @@map("faq_response_logs")
}

model Inquiry {
  id         String          @id @default(cuid())
  propertyId String
  name       String
  email      String
  phone      String?
  message    String
  type       String          @default("general")
  status     String          @default("new")
  source     String          @default("manual")
  checkIn    DateTime?
  checkOut   DateTime?
  guestCount Int?
  faqLogId   String?         @unique
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  faqLog     FaqResponseLog? @relation(fields: [faqLogId], references: [id])
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, status])
  @@index([propertyId, createdAt])
  @@map("inquiries")
}

model GuestCommunication {
  id          String    @id @default(cuid())
  propertyId  String
  guestId     String?
  type        String
  channel     String
  subject     String?
  content     String
  status      String    @default("pending")
  variables   Json?
  language    String?   @default("sl")
  scheduledAt DateTime?
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  templateId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  guest       Guest?    @relation(fields: [guestId], references: [id])
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, type, status])
  @@map("guest_communications")
}

model Amenity {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  category   String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("amenities")
}

model PropertyPolicy {
  id         String   @id @default(cuid())
  propertyId String
  policyType String
  content    String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_policies")
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  roomId     String?
  date       DateTime
  reason     String?
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room       Room?    @relation(fields: [roomId], references: [id])

  @@index([propertyId, date])
  @@index([roomId, date])
  @@map("blocked_dates")
}

model PageDesign {
  id         String     @id @default(cuid())
  userId     String
  title      String
  blocks     Json
  rawHtml    String?
  rawCss     String?
  version    Int        @default(1)
  published  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[] @relation("PageDesignProperties")

  @@index([userId, published])
  @@index([version])
  @@map("page_designs")
}

model PageBuilderTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?
  components  Json     @default("[]")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@map("page_builder_templates")
}

model PageBuilderPage {
  id           String   @id @default(cuid())
  userId       String?
  name         String?
  components   Json     @default("[]")
  lastModified DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("page_builder_pages")
}

model MCPBuilderState {
  id             String   @id @default(cuid())
  projectId      String   @unique
  components     Json     @default("[]")
  mcpConnections Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("mcp_builder_states")
}

model WorkflowExecution {
  id         String    @id @default(cuid())
  workflowId String
  status     String    @default("pending")
  logs       Json?
  result     Json?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_executions")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}
