generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// EVENT SOURCING MODELS
// ============================================================================

// Workflow Event Store
model WorkflowEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  aggregateId String   // ID agregata (npr. AgentRun ID)
  aggregateType String // Tip agregata (npr. 'AgentRun', 'Workflow')
  type        String   // Tip eventa (npr. 'AgentRunStarted')
  payload     Json     // Payload eventa
  version     Int      // Verzija eventa
  metadata    Json?    // Metadata (userId, correlationId, itd.)
  occurredAt  DateTime // Čas ko je dogodek nastal
  createdAt   DateTime @default(now())
  
  @@index([aggregateId])
  @@index([aggregateType])
  @@index([type])
  @@index([occurredAt])
  @@index([aggregateId, version])
  @@map("workflow_events")
}

// Workflow Snapshots (za optimizacijo loading-a)
model WorkflowSnapshot {
  id          String   @id @default(cuid())
  aggregateId String   @unique
  version     Int      // Verzija snapshot-a
  state       Json     // State agregata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([aggregateId])
  @@index([version])
  @@map("workflow_snapshots")
}

// Event Log (za auditing in debugging)
model EventLog {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String   // Tip eventa
  aggregateId String?  // ID agregata (optional)
  userId      String?  // ID userja ki je sprožil event
  payload     Json     // Payload
  metadata    Json?    // Metadata
  processed   Boolean  @default(false) // Ali je event procesiran
  error       String?  // Error če je processing failal
  createdAt   DateTime @default(now())
  processedAt DateTime?
  
  @@index([type])
  @@index([aggregateId])
  @@index([userId])
  @@index([processed])
  @@index([createdAt])
  @@map("event_log")
}

// ============================================================================
// ANALYTICS & PROJECTION MODELS
// ============================================================================

// Agent Run View (Read Model za queries)
model AgentRunView {
  id              String   @id @default(cuid())
  workflowId      String
  status          String   // pending, running, completed, failed
  inputData       Json?
  result          Json?
  error           String?
  errorType       String?
  totalSteps      Int      @default(0)
  totalDuration   Int      @default(0) // milliseconds
  totalTokensUsed Int      @default(0)
  userId          String?
  startedAt       DateTime?
  completedAt     DateTime?
  failedAtStep    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  steps           AgentRunStep[]
  
  @@index([workflowId])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("agent_run_view")
}

// Agent Run Step (Read Model)
model AgentRunStep {
  id          String   @id @default(cuid())
  runId       String
  name        String
  status      String   // pending, running, completed, failed
  input       Json?
  result      Json?
  error       String?
  duration    Int      @default(0) // milliseconds
  tokensUsed  Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  
  // Relations
  run         AgentRunView @relation(fields: [runId], references: [id], onDelete: Cascade)
  
  @@index([runId])
  @@index([status])
  @@map("agent_run_steps")
}

// Analytics Run Statistics
model AnalyticsRunStats {
  id            String   @id @default(cuid())
  workflowId    String   @unique
  totalRuns     Int      @default(0)
  successfulRuns Int     @default(0)
  failedRuns    Int      @default(0)
  avgDuration   Int      @default(0) // milliseconds
  avgTokens     Int      @default(0)
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([workflowId])
  @@map("analytics_run_stats")
}

// Analytics Daily Statistics
model AnalyticsDailyStats {
  id            String   @id @default(cuid())
  date          DateTime @unique
  totalRuns     Int      @default(0)
  completedRuns Int      @default(0)
  failedRuns    Int      @default(0)
  totalDuration Int      @default(0) // milliseconds
  totalTokens   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([date])
  @@map("analytics_daily_stats")
}

// ============================================================================
// END ANALYTICS & PROJECTION MODELS
// ============================================================================


// ============================================================================
// END EVENT SOURCING MODELS
// ============================================================================

// Template Usage Tracking
model TemplateUsage {
  id             String   @id @default(cuid())
  templateId     String
  system         String
  count          Int      @default(0)
  lastUsed       DateTime @updatedAt
  totalRenderTime Int     @default(0)
  errorCount     Int      @default(0)

  @@unique([templateId, system])
  @@index([system])
  @@index([lastUsed])
  @@map("template_usage")
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  name                     String?
  passwordHash             String?
  trialEndsAt              DateTime?
  activeTeamId             String?
  activePropertyId         String?
  role                     UserRole                  @default(VIEWER)
  aiQuota                  Int                       @default(100)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  emailVerified            DateTime?
  image                    String?
  alertConfiguration       Json?
  eturizemConfig           Json?
  stripeConfig             Json?
  sendGridConfig           Json?
  sentryConfig             Json?
  githubConfig             Json?
  vercelConfig             Json?
  firecrawlConfig          Json?
  notificationPreferences  Json?
  accounts                 Account[]
  blogPosts                BlogPost[]
  projects                 Project[]
  sessions                 Session[]
  subscription             Subscription?
  alertEvents              AlertEvent[]
  campaignBoards           CampaignBoard[]
  chatEscalations          ChatEscalation[]
  contentHistory           ContentHistory[]
  conversationThreads      ConversationThread[]
  itineraries              Itinerary[]
  landingPages             LandingPage[]
  notifications            Notification[]
  pageDesigns              PageDesign[]
  searchConsoleConnections SearchConsoleConnection[]
  seoMetrics               SeoMetric[]
  teamMembers              TeamMember[]
  ownedTeams               Team[]                    @relation("TeamOwner")
  translationJobs          TranslationJob[]
  usageAlerts              UsageAlert[]
  userTemplates            UserTemplate[]
  workflows                Workflow[]
  properties               Property[]                @relation("PropertyToUser")
  branding                 Branding?
  customRoles              CustomRole[]
  sentMessages             Message[]                 @relation("MessageSender")
  receivedMessages         Message[]                 @relation("MessageRecipient")
  messageGroups            MessageGroupMember[]
  ownerProfile             Owner?
  guestPreferences         GuestPreference[]         @relation("UserPreferences")

  @@map("users")
}

model BlogPost {
  id              String    @id @default(cuid())
  userId          String
  title           String?
  topic           String?
  fullContent     String?
  metaTitle       String?
  metaDescription String?
  imageUrl        String?
  pipelineStage   String?   @default("draft")
  brief           String?
  reviewedAt      DateTime?
  guardrailIssues Json?
  approvedBy      String?
  approvalStatus  String?   @default("pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageAlert {
  id          String    @id @default(cuid())
  userId      String
  type        String
  threshold   Int
  current     Int       @default(0)
  max         Int
  isTriggered Boolean   @default(false)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("usage_alerts")
}

model SmartAlertLog {
  id          String    @id @default(cuid())
  eventType   String
  entityId    String
  channel     String
  sentAt      DateTime  @default(now())
  escalatedAt DateTime?
  escalatedTo String?

  @@index([eventType, entityId, sentAt])
  @@map("smart_alert_logs")
}

model AlertRule {
  id                   String   @id @default(cuid())
  name                 String
  eventType            String
  threshold            Float?
  severity             String   @default("medium")
  enabled              Boolean  @default(true)
  channels             String[] @default(["email"])
  cooldownMinutes      Int      @default(60)
  escalateAfterMinutes Int?
  escalateTo           String?
  createdBy            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([eventType, enabled])
  @@map("alert_rules")
}

model AlertEvent {
  id             String    @id @default(cuid())
  type           String    @default("system_error")
  title          String
  message        String
  severity       String    @default("medium")
  status         String    @default("active")
  userId         String?
  propertyId     String?
  metadata       Json?
  acknowledgedBy String?
  acknowledgedAt DateTime?
  dismissedBy    String?
  dismissedAt    DateTime?
  createdAt      DateTime  @default(now())
  property       Property? @relation(fields: [propertyId], references: [id])
  user           User?     @relation(fields: [userId], references: [id])

  @@index([type, severity, status])
  @@index([userId, createdAt])
  @@index([propertyId, createdAt])
  @@map("alert_events")
}

model Workflow {
  id              String               @id @default(cuid())
  name            String
  description     String?
  userId          String
  propertyId      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  nodes           Json                 @default("[]")
  edges           Json                 @default("[]")
  metadata        Json?
  webhookToken    String?              @unique
  slackWebhookUrl String?
  status          String               @default("draft")
  agentId         String?
  currentVersion  Int                  @default(1)
  isTemplate      Boolean              @default(false)
  isSubWorkflow   Boolean              @default(false)
  parentWorkflowId String?
  checkpoints     WorkflowCheckpoint[]
  executions      WorkflowExecution[]
  versions        WorkflowVersion[]
  subWorkflows    Workflow[]           @relation("ParentSubWorkflow")
  parentWorkflow  Workflow?            @relation("ParentSubWorkflow", fields: [parentWorkflowId], references: [id])
  agent           Agent?               @relation(fields: [agentId], references: [id])
  property        Property?            @relation(fields: [propertyId], references: [id])
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@index([isTemplate])
  @@index([parentWorkflowId])
  @@map("workflows")
}

model WorkflowVersion {
  id              String    @id @default(cuid())
  workflowId      String
  versionNumber   Int
  name            String
  description     String?
  nodes           Json      @default("[]")
  edges           Json      @default("[]")
  metadata        Json?
  changeSummary   String?
  changeType      String    @default("minor") // major, minor, patch
  isCurrent       Boolean   @default(false)
  parentVersionId String?
  createdBy       String
  createdAt       DateTime  @default(now())
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  parentVersion   WorkflowVersion? @relation("WorkflowVersionHistory", fields: [parentVersionId], references: [id])
  childVersions   WorkflowVersion[] @relation("WorkflowVersionHistory")

  @@index([workflowId])
  @@index([versionNumber])
  @@index([isCurrent])
  @@map("workflow_versions")
}

model WorkflowCheckpoint {
  id              String    @id @default(cuid())
  workflowId      String
  nodeId          String
  nodeLabel       String?
  contextSnapshot Json
  status          String
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
}

model AgentRun {
  id              String   @id @default(cuid())
  userId          String?
  agentType       String
  workflowId      String?
  status          String
  input           Json?
  output          Json?
  creditsConsumed Int      @default(3)
  model           String?
  inputTokens     Int?
  outputTokens    Int?
  costEst         Float?
  latencyMs       Int?
  createdAt       DateTime @default(now())
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  value     String
  createdAt DateTime @default(now())

  @@unique([userId, provider])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String
  name      String?
  createdAt DateTime @default(now())

  @@index([keyHash])
  @@index([userId])
}

model Onboarding {
  id                String   @id @default(cuid())
  industry          String?
  companySize       String?
  workType          String?
  role              String?
  workspaceName     String?
  blogUrl           String?
  brandVoiceSummary String?
  styleGuide        String?
  visualGuidelines  String?
  audiences         Json?
  companyKnowledge  Json?
  userId            String?
  createdAt         DateTime @default(now())
}

model UserTemplate {
  id         String    @id @default(cuid())
  userId     String
  propertyId String?
  name       String
  category   String
  basePrompt String
  customVars Json?
  content    String?
  language   String?
  isPublic   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  property   Property? @relation(fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([propertyId])
  @@map("user_templates")
}

model LandingPage {
  id             String    @id @default(cuid())
  userId         String
  title          String
  slug           String?   @unique
  content        Json
  template       String    @default("tourism-basic")
  languages      String[]
  isPublished    Boolean   @default(false)
  publishedUrl   String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isPublished])
  @@index([propertyId])
  @@map("landing_pages")
}

model Property {
  id                           String               @id @default(cuid())
  userId                       String?
  ownerId                      String?
  name                         String
  location                     String?
  type                         String?
  capacity                     Int?
  description                  String?
  basePrice                    Float?
  currency                     String?              @default("EUR")
  seasonRates                  Json?
  pricingRules                 Json?
  reservationAutoApprovalRules Json?
  rnoId                        Int?
  googlePlaceId                String?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  eturizemId                   String?
  eturizemSyncStatus           String?              @default("not_mapped")
  eturizemSyncedAt             DateTime?
  eturizemLastError            String?
  ajpesConnection              AjpesConnection?
  owner                        Owner?               @relation(fields: [ownerId], references: [id])
  alertEvents                  AlertEvent[]
  amenities                    Amenity[]
  blockedDates                 BlockedDate[]
  competitors                  Competitor[]
  employees                    Employee[]
  faqResponseLogs              FaqResponseLog[]
  communications               GuestCommunication[]
  guests                       Guest[]
  housekeepingTasks            HousekeepingTask[]
  inquiries                    Inquiry[]
  itineraries                  Itinerary[]
  landingPages                 LandingPage[]
  pmsConnections               PmsConnection[]
  policies                     PropertyPolicy[]
  reservations                 Reservation[]
  reviews                      Review[]
  rooms                        Room[]
  seoMetrics                   SeoMetric[]
  staffAssignments             StaffAssignment[]
  userTemplates                UserTemplate[]
  workflows                    Workflow[]
  pageDesigns                  PageDesign[]         @relation("PageDesignProperties")
  users                        User[]               @relation("PropertyToUser")
  invoices                     Invoice[]            @relation("PropertyInvoices")
  revenueSplits                RevenueSplit[]
  staffSchedules               StaffSchedule[]
  sustainabilityMetrics        SustainabilityMetric[]
  ecoPractices                 EcoPractice[]
  ecoCertifications            EcoCertification[]
  photoAnalyses                PhotoAnalysis[]
  taskCollaborations           TaskCollaboration[]
  performanceMetrics           PerformanceMetric[]

  @@map("properties")
}

model Review {
  id             String       @id @default(cuid())
  propertyId     String
  reservationId  String?      @unique
  guestId        String?
  rating         Float
  title          String?
  content        String
  platform       String       @default("direct")
  status         String       @default("pending")
  sentiment      String?
  sentimentScore Float?
  response       String?
  respondedAt    DateTime?
  respondedBy    String?
  categories     Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  guest          Guest?       @relation(fields: [guestId], references: [id])
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation    Reservation? @relation(fields: [reservationId], references: [id])

  @@index([propertyId, status])
  @@index([platform])
  @@map("reviews")
}

