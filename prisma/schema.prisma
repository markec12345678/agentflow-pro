generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  passwordHash     String?
  trialEndsAt      DateTime?
  activeTeamId     String?
  activePropertyId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  workflows        Workflow[]
  subscription     Subscription?
  blogPosts        BlogPost[]
  ownedTeams       Team[]           @relation("TeamOwner")
  teamMembers      TeamMember[]
  campaignBoards   CampaignBoard[]
  userTemplates    UserTemplate[]
  landingPages     LandingPage[]
  seoMetrics       SeoMetric[]
  translationJobs  TranslationJob[]
  properties       Property[]
  itineraries      Itinerary[]
}

model BlogPost {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  topic           String?
  fullContent     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  imageUrl        String?
  pipelineStage   String?   @default("draft")
  brief           String?   @db.Text
  reviewedAt      DateTime?
  guardrailIssues Json?
  approvedBy      String?
  approvalStatus  String?   @default("pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, createdAt])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Workflow {
  id              String   @id @default(cuid())
  name            String
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  nodes           Json     @default("[]")
  edges           Json     @default("[]")
  metadata        Json?
  webhookToken    String?  @unique
  slackWebhookUrl String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id         String   @id @default(cuid())
  userId     String?
  agentType  String
  workflowId String?
  status     String
  input      Json?
  output     Json?
  createdAt  DateTime @default(now())
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String // session.userId (ali email za in-memory auth)
  provider  String // firecrawl, context7, brave, openai, github, vercel, netlify
  value     String // encrypted ali plain (za MVP plain, kasneje encrypt)
  createdAt DateTime @default(now())

  @@unique([userId, provider])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String // hash of the key for lookup (MVP: store plain in keyHash for simplicity)
  name      String?
  createdAt DateTime @default(now())

  @@index([keyHash])
  @@index([userId])
}

model Onboarding {
  id                String   @id @default(cuid())
  industry          String?
  companySize       String?
  workType          String?
  role              String?
  workspaceName     String?
  blogUrl           String?
  brandVoiceSummary String?
  styleGuide        String?
  visualGuidelines  String?
  audiences         Json?
  companyKnowledge  Json?
  userId            String?
  createdAt         DateTime @default(now())
}

model UserTemplate {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  name       String
  category   String
  basePrompt String
  customVars Json?
  content    String?  @db.Text
  language   String?
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, category])
  @@index([propertyId])
  @@map("user_templates")
}

model LandingPage {
  id             String   @id @default(cuid())
  userId         String
  title          String
  slug           String?  @unique
  content        Json
  template       String   @default("tourism-basic")
  languages      String[]
  isPublished    Boolean  @default(false)
  publishedUrl   String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  propertyId     String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, isPublished])
  @@index([propertyId])
  @@map("landing_pages")
}

model Property {
  id        String   @id @default(cuid())
  userId    String
  name      String
  location  String?
  type      String?
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  landingPages  LandingPage[]
  userTemplates UserTemplate[]
  itineraries   Itinerary[]

  @@index([userId])
  @@map("properties")
}

model Itinerary {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  title      String
  days       Json // [{ day: 1, date?: string, activities: [{ time?, title, desc, location? }] }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([propertyId])
  @@map("itineraries")
}

model SeoMetric {
  id           String    @id @default(cuid())
  userId       String
  contentId    String?
  contentType  String
  keyword      String
  position     Int?
  searchVolume Int?
  difficulty   Int?
  lastChecked  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType, keyword])
  @@map("seo_metrics")
}

model TranslationJob {
  id            String    @id @default(cuid())
  userId        String
  sourceContent String
  sourceLang    String    @default("sl")
  targetLangs   String[]
  status        String    @default("pending")
  results       Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("translation_jobs")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  plan      String?
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Team {
  id            String         @id @default(cuid())
  name          String
  ownerId       String
  owner         User           @relation("TeamOwner", fields: [ownerId], references: [id])
  members       TeamMember[]
  campaignBoards CampaignBoard[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member")
  user      User     @relation(fields: [userId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId])
  @@index([teamId])
  @@map("team_members")
}

model CampaignBoard {
  id        String   @id @default(cuid())
  name      String
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([userId])
  @@map("campaign_boards")
}
