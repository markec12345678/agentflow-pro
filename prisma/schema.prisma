generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  name                     String?
  passwordHash             String?
  trialEndsAt              DateTime?
  activeTeamId             String?
  activePropertyId         String?
  role                     UserRole                  @default(VIEWER)
  aiQuota                  Int                       @default(100)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  workflows                Workflow[]
  subscription             Subscription?
  blogPosts                BlogPost[]
  ownedTeams               Team[]                    @relation("TeamOwner")
  teamMembers              TeamMember[]
  campaignBoards           CampaignBoard[]
  userTemplates            UserTemplate[]
  landingPages             LandingPage[]
  seoMetrics               SeoMetric[]
  translationJobs          TranslationJob[]
  properties               Property[]
  itineraries              Itinerary[]
  conversationThreads      ConversationThread[]
  chatEscalations          ChatEscalation[]
  projects                 Project[]
  accounts                 Account[]
  sessions                 Session[]
  emailVerified            DateTime?
  image                    String?
  notifications            Notification[]
  contentHistory           ContentHistory[]
  searchConsoleConnections SearchConsoleConnection[]
  pageDesigns              PageDesign[]
  usageAlerts              UsageAlert[]

  @@map("users")
}

model BlogPost {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String?
  topic           String?
  fullContent     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  imageUrl        String?
  pipelineStage   String?   @default("draft")
  brief           String?   @db.Text
  reviewedAt      DateTime?
  guardrailIssues Json?
  approvedBy      String?
  approvalStatus  String?   @default("pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, createdAt])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planId               String
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model UsageAlert {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  threshold   Int
  current     Int       @default(0)
  max         Int
  isTriggered Boolean   @default(false)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("usage_alerts")
}

model Workflow {
  id              String               @id @default(cuid())
  name            String
  userId          String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  nodes           Json                 @default("[]")
  edges           Json                 @default("[]")
  metadata        Json?
  webhookToken    String?              @unique
  slackWebhookUrl String?
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkpoints     WorkflowCheckpoint[]
  agentId         String?
  agent           Agent?               @relation(fields: [agentId], references: [id])
}

model WorkflowCheckpoint {
  id              String    @id @default(cuid())
  workflowId      String
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeId          String
  nodeLabel       String?
  contextSnapshot Json // Full context at pause; used to resume
  status          String // pending_approval | approved | rejected
  approvedAt      DateTime?
  approvedBy      String? // userId
  rejectionReason String?
  createdAt       DateTime  @default(now())

  @@index([workflowId])
  @@index([status])
}

model AgentRun {
  id              String   @id @default(cuid())
  userId          String?
  agentType       String
  workflowId      String?
  status          String
  input           Json?
  output          Json?
  creditsConsumed Int      @default(3)
  model           String?
  inputTokens     Int?
  outputTokens    Int?
  costEst         Float?
  latencyMs       Int?
  createdAt       DateTime @default(now())
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String // session.userId (ali email za in-memory auth)
  provider  String // firecrawl, context7, brave, openai, github, vercel, netlify
  value     String // encrypted ali plain (za MVP plain, kasneje encrypt)
  createdAt DateTime @default(now())

  @@unique([userId, provider])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String // hash of the key for lookup (MVP: store plain in keyHash for simplicity)
  name      String?
  createdAt DateTime @default(now())

  @@index([keyHash])
  @@index([userId])
}

model Onboarding {
  id                String   @id @default(cuid())
  industry          String?
  companySize       String?
  workType          String?
  role              String?
  workspaceName     String?
  blogUrl           String?
  brandVoiceSummary String?
  styleGuide        String?
  visualGuidelines  String?
  audiences         Json?
  companyKnowledge  Json?
  userId            String?
  createdAt         DateTime @default(now())
}

model UserTemplate {
  id         String   @id @default(cuid())
  userId     String
  propertyId String?
  name       String
  category   String
  basePrompt String
  customVars Json?
  content    String?  @db.Text
  language   String?
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, category])
  @@index([propertyId])
  @@map("user_templates")
}

model LandingPage {
  id             String   @id @default(cuid())
  userId         String
  title          String
  slug           String?  @unique
  content        Json
  template       String   @default("tourism-basic")
  languages      String[]
  isPublished    Boolean  @default(false)
  publishedUrl   String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  propertyId     String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, isPublished])
  @@index([propertyId])
  @@map("landing_pages")
}

model Property {
  id              String               @id @default(cuid())
  userId          String?
  name            String
  location        String?
  type            String?
  capacity        Int?
  description     String?
  basePrice       Float?
  currency        String?              @default("EUR")
  seasonRates     Json? // { high: [{from,to,rate}], mid: [...], low: [...] }
  rnoId           Int? // RNO ID nastanitvenega obrata (AJPES)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  landingPages    LandingPage[]
  userTemplates   UserTemplate[]
  itineraries     Itinerary[]
  reservations    Reservation[]
  guests          Guest[]
  competitors     Competitor[]
  faqResponseLogs FaqResponseLog[]
  inquiries       Inquiry[]
  amenities       Amenity[]
  policies        PropertyPolicy[]
  communications  GuestCommunication[]
  seoMetrics      SeoMetric[]
  blockedDates    BlockedDate[]
  pageDesigns     PageDesign[]         @relation("PageDesignProperties")
  users           User[]
  pmsConnections  PmsConnection[]
  ajpesConnection AjpesConnection?

  @@map("properties")
}

model AjpesConnection {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  username    String
  passwordEnc String
  rnoId       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId])
  @@index([propertyId])
  @@map("ajpes_connections")
}

model PmsConnection {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  provider    String
  credentials Json // { accessToken, clientToken }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([propertyId, provider])
  @@index([propertyId])
  @@map("pms_connections")
}

model Itinerary {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  title      String
  days       Json // [{ day: 1, date?: string, activities: [{ time?, title, desc, location? }] }]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@map("itineraries")
}

model SeoMetric {
  id           String    @id @default(cuid())
  userId       String
  propertyId   String?
  contentId    String?
  contentType  String
  keyword      String
  position     Int?
  searchVolume Int?
  difficulty   Int?
  clicks       Int?
  impressions  Int?
  date         DateTime?
  lastChecked  DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, contentType, keyword])
  @@index([propertyId, date])
  @@map("seo_metrics")
}

model TranslationJob {
  id            String    @id @default(cuid())
  userId        String
  sourceContent String
  sourceLang    String    @default("sl")
  targetLangs   String[]
  status        String    @default("pending")
  results       Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("translation_jobs")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  plan      String?
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Team {
  id             String          @id @default(cuid())
  name           String
  ownerId        String
  owner          User            @relation("TeamOwner", fields: [ownerId], references: [id])
  members        TeamMember[]
  campaignBoards CampaignBoard[]
  invites        Invite[]
  workspaces     Workspace[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ownerId])
  @@map("teams")
}

model Workspace {
  id             String          @id @default(cuid())
  teamId         String
  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name           String
  type           String // content_pipeline | campaign
  campaignBoards CampaignBoard[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([teamId])
  @@map("workspaces")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member")
  user      User     @relation(fields: [userId], references: [id])
  team      Team     @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId])
  @@index([teamId])
  @@map("team_members")
}

model CampaignBoard {
  id          String     @id @default(cuid())
  name        String
  teamId      String
  team        Team       @relation(fields: [teamId], references: [id])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  data        Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([teamId])
  @@index([userId])
  @@index([workspaceId])
  @@map("campaign_boards")
}

model Invite {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([teamId])
  @@map("invites")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model ConversationThread {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentThreadId String?
  parentThread   ConversationThread?  @relation("ThreadBranches", fields: [parentThreadId], references: [id], onDelete: SetNull)
  branches       ConversationThread[] @relation("ThreadBranches")
  messages       Json                 @default("[]") // [{ id, role, content }]
  title          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  escalations    ChatEscalation[]

  @@index([userId])
  @@index([parentThreadId])
  @@map("conversation_threads")
}

model ChatEscalation {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadId           String?
  thread             ConversationThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  lastMessagePreview String              @db.Text
  confidence         Float
  status             String              @default("pending") // pending | acknowledged | resolved
  createdAt          DateTime            @default(now())

  @@index([userId])
  @@index([threadId])
  @@index([status])
  @@map("chat_escalations")
}

model Agent {
  id          String     @id @default(uuid())
  name        String
  description String?
  role        String     @default("assistant")
  status      String     @default("active")
  avatar      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workflows   Workflow[]
  projects    Project[]
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  html        String
  css         String?
  js          String?
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Tourism models
model Reservation {
  id                  String    @id @default(cuid())
  propertyId          String
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestId             String?
  guest               Guest?    @relation(fields: [guestId], references: [id], onDelete: SetNull)
  roomId              String?
  checkIn             DateTime
  checkOut            DateTime
  status              String    @default("confirmed") // confirmed, cancelled, pending
  channel             String? // direct, booking.com, airbnb, etc.
  totalPrice          Float?
  deposit             Float? // zahtevana akontacija
  touristTax          Float? // turistična taksa (skupni znesek)
  notes               String?
  checkInToken        String?   @unique // za check-in povezavo (eTurizem)
  eturizemSubmittedAt DateTime?
  payments            Payment[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([propertyId, checkIn])
  @@index([status])
  @@map("reservations")
}

model Payment {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          String // deposit, balance, tourist_tax, extra
  amount        Float
  currency      String      @default("EUR")
  paidAt        DateTime    @default(now())
  method        String? // cash, card, transfer
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([reservationId])
  @@map("payments")
}

model Guest {
  id           String    @id @default(cuid())
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  name         String
  email        String?
  phone        String?
  dateOfBirth  DateTime? // za eTurizem
  countryCode  String? // ISO 2 (SI, DE)
  documentType String? // vrstaDok: F,H,I,O,P,U,V,L
  documentId   String? // idStDok
  gender       String? // M / F
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  reservations   Reservation[]
  communications GuestCommunication[]

  @@index([propertyId])
  @@map("guests")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String?
  title      String
  message    String
  type       String // info, warning, error, success
  read       Boolean  @default(false)
  link       String?
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([propertyId])
  @@map("notifications")
}

model ContentHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String?
  content    String   @db.Text
  type       String // blog, landing, social, etc.
  status     String // draft, published, archived
  promptType String? // ai, manual, template
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, propertyId, type])
  @@map("content_history")
}

model SearchConsoleConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId   String?
  siteUrl      String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  lastSync     DateTime?
  status       String? // active, inactive, error
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, siteUrl])
  @@index([propertyId])
  @@map("search_console_connections")
}

model Competitor {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  url        String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  prices CompetitorPrice[]

  @@index([propertyId])
  @@map("competitors")
}

model CompetitorPrice {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  date         DateTime
  price        Float
  roomType     String?
  createdAt    DateTime   @default(now())

  @@index([competitorId, date])
  @@map("competitor_prices")
}

model FaqResponseLog {
  id             String    @id @default(cuid())
  question       String    @db.Text
  responseTimeMs Int
  confidence     Float
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  inquiry        Inquiry?
  createdAt      DateTime  @default(now())

  @@index([propertyId, createdAt])
  @@map("faq_response_logs")
}

model Inquiry {
  id         String          @id @default(cuid())
  propertyId String
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  email      String
  phone      String?
  message    String          @db.Text
  type       String          @default("general") // general | availability | group | offer
  status     String          @default("new") // new | read | replied | closed
  source     String          @default("manual") // manual | faq_escalation | form
  checkIn    DateTime?
  checkOut   DateTime?
  guestCount Int?
  faqLogId   String?         @unique
  faqLog     FaqResponseLog? @relation(fields: [faqLogId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([propertyId, status])
  @@index([propertyId, createdAt])
  @@map("inquiries")
}

model GuestCommunication {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  guestId    String?
  guest      Guest?    @relation(fields: [guestId], references: [id], onDelete: SetNull)
  type       String // pre-arrival, post-stay, inquiry, complaint
  channel    String // email, sms, phone
  subject    String?
  content    String    @db.Text
  status     String    @default("pending") // pending, sent, failed
  variables  Json? // template variables
  sentAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([propertyId, type, status])
  @@map("guest_communications")
}

model Amenity {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String // WiFi, Parkirišče, Bazen, ...
  category   String? // connectivity, parking, facilities
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@map("amenities")
}

model PropertyPolicy {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  policyType String // cancellation, check-in, pets, ...
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@map("property_policies")
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomId     String?
  date       DateTime
  reason     String?
  createdAt  DateTime @default(now())

  @@index([propertyId, date])
  @@index([roomId, date])
  @@map("blocked_dates")
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

model PageDesign {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties Property[] @relation("PageDesignProperties")
  title      String
  blocks     Json // Aura block structure with versioning
  rawHtml    String? // GrapesJS fallback
  rawCss     String?
  version    Int        @default(1)
  published  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([userId, published])
  @@index([version])
  @@map("page_designs")
}

model PageBuilderTemplate {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  description String?
  components  Json     @default("[]")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@map("page_builder_templates")
}

model PageBuilderPage {
  id           String   @id @default(cuid())
  userId       String?
  name         String?
  components   Json     @default("[]")
  lastModified DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("page_builder_pages")
}
