model ReviewRequest {
  id             String   @id @default(cuid())
  reservationId  String
  propertyId     String
  guestEmail     String
  guestPhone     String?
  guestName      String
  reviewUrl      String
  channel        String   @default("both") // email, sms, both
  status         String   @default("pending") // pending, sent, completed, failed
  scheduledFor   DateTime?
  sentAt         DateTime?
  completedAt    DateTime?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([reservationId])
  @@index([propertyId])
  @@index([status])
  @@index([scheduledFor])
  @@map("review_requests")
}

model Room {
  id                String             @id @default(cuid())
  propertyId        String
  name              String
  type              String
  capacity          Int
  beds              Int?
  description       String?
  basePrice         Float?
  amenities         String[]
  photos            String[]
  seasonRates       Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  blockedDates      BlockedDate[]
  reservations      Reservation[]
  housekeepingTasks HousekeepingTask[]
  property          Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("rooms")
}

model AjpesConnection {
  id          String   @id @default(cuid())
  propertyId  String   @unique
  username    String
  passwordEnc String
  rnoId       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("ajpes_connections")
}

model PmsConnection {
  id          String   @id @default(cuid())
  propertyId  String
  provider    String
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, provider])
  @@index([propertyId])
  @@map("pms_connections")
}

model Itinerary {
  id         String    @id @default(cuid())
  userId     String
  propertyId String?
  title      String
  days       Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  property   Property? @relation(fields: [propertyId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
  @@map("itineraries")
}

model SeoMetric {
  id           String    @id @default(cuid())
  userId       String
  propertyId   String?
  contentId    String?
  contentType  String
  keyword      String
  position     Int?
  searchVolume Int?
  difficulty   Int?
  clicks       Int?
  impressions  Int?
  date         DateTime?
  lastChecked  DateTime?
  property     Property? @relation(fields: [propertyId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType, keyword])
  @@index([propertyId, date])
  @@map("seo_metrics")
}

model TranslationJob {
  id            String    @id @default(cuid())
  userId        String
  sourceContent String
  sourceLang    String    @default("sl")
  targetLangs   String[]
  status        String    @default("pending")
  results       Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("translation_jobs")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  plan      String?
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Team {
  id             String          @id @default(cuid())
  name           String
  ownerId        String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  campaignBoards CampaignBoard[]
  invites        Invite[]
  members        TeamMember[]
  owner          User            @relation("TeamOwner", fields: [ownerId], references: [id])
  workspaces     Workspace[]

  @@index([ownerId])
  @@map("teams")
}

model Workspace {
  id             String          @id @default(cuid())
  teamId         String
  name           String
  type           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  campaignBoards CampaignBoard[]
  team           Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("workspaces")
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
  @@index([teamId])
  @@map("team_members")
}

model CampaignBoard {
  id          String     @id @default(cuid())
  name        String
  teamId      String
  workspaceId String?
  userId      String
  data        Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  team        Team       @relation(fields: [teamId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([teamId])
  @@index([userId])
  @@index([workspaceId])
  @@map("campaign_boards")
}

model Invite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([teamId])
  @@map("invites")
}

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("integrations")
}

model ConversationThread {
  id             String               @id @default(cuid())
  userId         String
  parentThreadId String?
  messages       Json                 @default("[]")
  title          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  escalations    ChatEscalation[]
  parentThread   ConversationThread?  @relation("ThreadBranches", fields: [parentThreadId], references: [id])
  branches       ConversationThread[] @relation("ThreadBranches")
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentThreadId])
  @@map("conversation_threads")
}

model ChatEscalation {
  id                 String              @id @default(cuid())
  userId             String
  threadId           String?
  lastMessagePreview String
  confidence         Float
  status             String              @default("pending")
  createdAt          DateTime            @default(now())
  thread             ConversationThread? @relation(fields: [threadId], references: [id])
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
