  verifiedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  property        Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([status])
  @@map("eco_certifications")
}

// Voice Assistant - Conversation Logs
model VoiceInteraction {
  id              String   @id @default(cuid())
  userId          String?
  propertyId      String?
  sessionId       String
  interactionType String   // inquiry, command, booking
  audioUrl        String?
  transcript      String
  intent          String
  confidence      Float?
  response        String?
  responseAudioUrl String?
  duration        Int?     // seconds
  language        String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([propertyId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("voice_interactions")
}

// Performance Tracking - Employee KPIs
model PerformanceMetric {
  id              String   @id @default(cuid())
  employeeId      String
  propertyId      String?
  metricType      String   // tasks_completed, guest_rating, response_time
  value           Float
  target          Float?
  unit            String   // count, percentage, minutes
  period          String   // daily, weekly, monthly
  periodStart     DateTime
  periodEnd       DateTime
  rating          String?  // poor, fair, good, excellent
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        Employee @relation(fields: [employeeId], references: [id])
  property        Property? @relation(fields: [propertyId], references: [id])

  @@index([employeeId])
  @@index([propertyId])
  @@index([periodStart, periodEnd])
  @@map("performance_metrics")
}

model TaskCollaboration {
  id              String   @id @default(cuid())
  propertyId      String
  title           String
  description     String?
  type            String   // housekeeping, maintenance, guest-request, admin
  priority        String   @default("medium") // low, medium, high, urgent
  status          String   @default("open") // open, in-progress, completed, cancelled
  assigneeId      String?
  creatorId       String
  dueDate         DateTime?
  completedAt     DateTime?
  completedBy     String?
  tags            String[]
  attachments     Json?    // [{url, type}]
  comments        Json?    // [{userId, text, createdAt}]
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  property        Property @relation(fields: [propertyId], references: [id])
  assignee        Employee? @relation(fields: [assigneeId], references: [id], name: "TaskAssignee")

  @@index([propertyId])
  @@index([status])
  @@index([assigneeId])
  @@index([createdAt])
  @@map("task_collaborations")
}

model OwnerDocument {
  id              String   @id @default(cuid())
  ownerId         String
  propertyId      String?
  title           String
  description     String?
  category        String   // financial, legal, operational, marketing
  fileUrl         String
  fileType        String   // pdf, docx, xlsx, image
  fileSize        Int?     // bytes
  uploadedBy      String
  visibility      String   @default("private") // private, shared, public
  sharedWith      String[] // user IDs
  downloadCount   Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  owner           Owner    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([propertyId])
  @@index([category])
  @@map("owner_documents")
}

model OwnerReport {
  id              String   @id @default(cuid())
  ownerId         String
  propertyId      String?
  reportType      String   // revenue, occupancy, performance, sustainability
  period          String   // daily, weekly, monthly, quarterly, yearly
  periodStart     DateTime
  periodEnd       DateTime
  data            Json     // report metrics
  generatedAt     DateTime @default(now())
  sentAt          DateTime?
  sentTo          String[]
  status          String   @default("generated") // generated, sent, viewed
  fileUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  owner           Owner    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])                                                            
  @@index([propertyId])                                                          
  @@index([reportType])                                                          
  @@index([periodStart, periodEnd])                                              
  @@map("owner_reports")                                                         
}

// ============================================================================
// INVOICING & TAX MODELS
// ============================================================================

model TouristTaxRate {
  id           String   @id @default(cuid())
  municipality String   @unique
  adults       Decimal
  children7_18 Decimal
  children0_7  Decimal
  spaTax       Decimal?
  validFrom    DateTime @default(now())
  validTo      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([municipality])
  @@map("tourist_tax_rates")
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  reservationId   String
  guestId         String
  propertyId      String
  
  // Dates
  invoiceDate     DateTime @default(now())
  dueDate         DateTime
  checkIn         DateTime
  checkOut        DateTime
  
  // Amounts
  accommodation   Decimal
  touristTax      Decimal
  vatRate         Decimal  @default(22)
  vatAmount       Decimal
  total           Decimal
  
  // Status
  status          String   @default("draft") // draft, sent, paid, overdue, cancelled
  sentAt          DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  
  // PDF
  pdfUrl          String?
  
  // Metadata
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  reservation     Reservation @relation(fields: [reservationId], references: [id])
  property        Property    @relation(fields: [propertyId], references: [id], name: "PropertyInvoices")
  guest           Guest       @relation(fields: [guestId], references: [id], name: "GuestInvoices")
  
  @@index([reservationId])
  @@index([guestId])
  @@index([propertyId])
  @@index([status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@map("invoices")
}

model TaxReport {
  id              String   @id @default(cuid())
  propertyId      String
  propertyName    String
  
  // Period
  month           DateTime // First day of month
  year            Int
  monthNumber     Int      // 1-12
  
  // Totals
  totalNights     Int
  totalGuests     Int
  totalAdults     Int
  totalChildren   Int
  
  // Tax amounts
  touristTaxAmount Decimal
  vatAmount        Decimal
  totalAccommodation Decimal
  
  // Status
  status          String   @default("draft") // draft, submitted, paid
  submittedAt     DateTime?
  paidAt          DateTime?
  
  // eDavki export
  edavkiExportUrl String?
  edavkiSubmittedAt DateTime?
  
  // Metadata
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([propertyId, year, monthNumber])
  @@index([status])
  @@index([month])
  @@map("tax_reports")
}
