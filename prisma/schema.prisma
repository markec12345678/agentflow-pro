  senderId   String
  recipientId String?
  groupId    String?
  content    String   @db.Text
  isRead     Boolean  @default(false)
  readAt     DateTime?
  messageType String  @default("direct") // direct, group, announcement
  attachments Json?    // [{url, name, type}]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade, name: "MessageSender")
  recipient  User?    @relation(fields: [recipientId], references: [id], onDelete: Cascade, name: "MessageRecipient")
  group      MessageGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([recipientId])
  @@index([groupId])
  @@index([createdAt])
